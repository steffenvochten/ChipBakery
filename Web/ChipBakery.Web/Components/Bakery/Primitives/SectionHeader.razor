@* Section heading with hand-lettered Caveat eyebrow + serif title + dashed sketch underline.
   Used at the top of every page section. *@

<div class="@($"mb-6 {Class}".Trim())">
    @if (!string.IsNullOrEmpty(Eyebrow))
    {
        <div class="display-hand text-xl text-kraft mb-1 leading-none">@Eyebrow</div>
    }
    <h2 class="font-serif font-bold text-3xl sm:text-4xl text-ink tracking-tight underline-sketch inline-block">
        @ChildContent
    </h2>
    @if (Subtitle is not null)
    {
        <p class="mt-2 text-ink-muted max-w-2xl">@Subtitle</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    /// <summary>Hand-lettered Caveat label rendered above the title (e.g. "today's").</summary>
    [Parameter] public string? Eyebrow { get; set; }

    /// <summary>Optional supporting copy below the title.</summary>
    [Parameter] public RenderFragment? Subtitle { get; set; }

    [Parameter] public string Class { get; set; } = "";
}
