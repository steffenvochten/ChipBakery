@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject ChipBakery.Web.Services.TimezoneService TzService
@implements IDisposable

<div class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-40">
        <div class="chalkboard-surface mx-3 sm:mx-6 mt-3 sm:mt-4 px-4 sm:px-6 py-3 shadow-deep rounded-2xl">
            <div class="max-w-7xl mx-auto">
                <NavMenu OnMobileToggle="ToggleDrawer" />
            </div>
        </div>
    </header>

    <main class="flex-1 py-8 sm:py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
            @Body
        </div>
    </main>

    <footer class="py-10 mt-12 border-t" style="border-color: rgb(var(--ink) / 0.08);">
        <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-ink-muted">
            <div class="flex items-center gap-3">
                <Doodle Name="deco-wheat" Class="w-5 h-5" />
                <span class="display-hand text-lg leading-none">made with butter and time</span>
            </div>
            <div class="text-sm">
                &copy; @DateTime.Now.Year ChipBakery
                <span class="opacity-70">— artisanal since 2024</span>
            </div>
        </div>
    </footer>
</div>

<MobileDrawer Open="_drawerOpen" OpenChanged="@(b => _drawerOpen = b)" />

<div id="blazor-error-ui" data-nosnippet>
    <div class="flex items-center justify-between gap-4">
        <span>An unhandled error has occurred.</span>
        <div class="flex items-center gap-3">
            <a href="." class="underline font-bold">Reload</a>
            <span class="dismiss text-xl">&times;</span>
        </div>
    </div>
</div>

@code {
    private bool _drawerOpen;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !TzService.IsInitialized)
        {
            // JS getTimezoneOffset() → minutes to subtract from local to get UTC
            // e.g. CEST (UTC+2) returns -120
            var offset = await JS.InvokeAsync<int>("eval", "new Date().getTimezoneOffset()");
            TzService.Initialize(offset);
            StateHasChanged();
        }
    }

    public void Dispose() { }
}
