<div class="flex items-center justify-between">
    <a class="flex items-center gap-2 group" href="">
        <div class="w-8 h-8 bg-bakery-crust rounded-xl flex items-center justify-center text-bakery-dough shadow-sm group-hover:scale-110 transition-transform duration-300">
            <span class="font-serif font-black text-xs">CB</span>
        </div>
        <span class="font-serif font-black text-xl tracking-tight text-bakery-crust dark:text-amber-500">ChipBakery</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
        <NavLink class="px-3 py-2 rounded-full text-sm font-bold transition-all hover:bg-bakery-crust/5" href="" Match="NavLinkMatch.All">Storefront</NavLink>
        <NavLink class="px-3 py-2 rounded-full text-sm font-bold transition-all hover:bg-bakery-crust/5" href="orders">Orders</NavLink>
        <NavLink class="px-3 py-2 rounded-full text-sm font-bold transition-all hover:bg-bakery-crust/5" href="inventory">Inventory</NavLink>
        <NavLink class="px-3 py-2 rounded-full text-sm font-bold transition-all hover:bg-bakery-crust/5" href="production">Production</NavLink>
        <NavLink class="px-3 py-2 rounded-full text-sm font-bold transition-all hover:bg-bakery-crust/5" href="warehouse">Warehouse</NavLink>
        <NavLink class="px-3 py-2 rounded-full text-sm font-bold transition-all hover:bg-bakery-crust/5" href="loyalty">Loyalty</NavLink>
        <NavLink class="px-3 py-2 rounded-full text-sm font-bold transition-all hover:bg-bakery-crust/5" href="supplier">Supplier</NavLink>
    </nav>

    <div class="flex items-center gap-2">
        <button class="w-10 h-10 flex items-center justify-center rounded-2xl hover:bg-bakery-crust/5 transition-colors group" onclick="toggleTheme()" title="Toggle theme">
            <svg class="w-5 h-5 text-bakery-crust dark:text-amber-500 group-hover:rotate-12 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
        </button>
        <button class="md:hidden w-10 h-10 flex items-center justify-center rounded-2xl hover:bg-bakery-crust/5 transition-colors" title="Menu">
            <svg class="w-6 h-6 text-bakery-crust" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
            </svg>
        </button>
    </div>
</div>

@code {
    // We can bridge the JS toggleTheme call if we want to trigger it from C#, 
    // but the original was native JS onclick. Let's keep it simple for now as per plan.
}
