@* Chalkboard top nav. Items render as menu lines with a hand-drawn dashed underline
   for the active route. Mobile shows a hamburger that opens MobileDrawer. *@

<div class="flex items-center justify-between gap-4">
    <a class="flex items-center gap-3 group flex-shrink-0" href="">
        <div class="w-9 h-9 rounded-2xl flex items-center justify-center group-hover:rotate-6 transition-transform duration-300"
             style="background-color: rgb(var(--chocolate)); color: rgb(var(--paper));">
            <Doodle Name="deco-wheat" Class="w-6 h-6" />
        </div>
        <span class="display-hand text-2xl leading-none" style="color: rgb(var(--ink));">ChipBakery</span>
    </a>

    <nav class="hidden lg:flex items-center gap-0.5 flex-1 justify-end">
        @foreach (var (href, label, glyph, accent) in _items)
        {
            <NavLink href="@href"
                     Match="@(href == "" ? NavLinkMatch.All : NavLinkMatch.Prefix)"
                     class="@($"{LinkBase} {(accent ? "accent-link" : "")}".Trim())">
                @if (!string.IsNullOrEmpty(glyph))
                {
                    <Doodle Name="@glyph" Class="w-4 h-4 inline-block mr-1.5 -mt-0.5" ViewBox="0 0 24 24" />
                }
                @label
            </NavLink>
        }
    </nav>

    <div class="flex items-center gap-1 flex-shrink-0">
        <button class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-ink/5 transition-colors group"
                onclick="toggleTheme()"
                title="Toggle theme"
                aria-label="Toggle theme">
            <span class="block dark:hidden" style="color: rgb(var(--ink));">
                <Doodle Name="glyph-sun" Class="w-5 h-5 group-hover:rotate-45 transition-transform duration-300" ViewBox="0 0 24 24" />
            </span>
            <span class="hidden dark:block" style="color: rgb(var(--ink));">
                <Doodle Name="glyph-moon" Class="w-5 h-5 group-hover:-rotate-12 transition-transform duration-300" ViewBox="0 0 24 24" />
            </span>
        </button>
        <button class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl hover:bg-ink/5 transition-colors"
                title="Menu"
                aria-label="Open menu"
                @onclick="HandleMobileToggle">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: rgb(var(--ink));">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
            </svg>
        </button>
    </div>
</div>

<style>
    .nav-link {
        position: relative;
        padding: 0.4rem 0.7rem;
        border-radius: 0.625rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        color: rgb(var(--ink));
        opacity: 0.75;
        transition: opacity 200ms ease, background-color 200ms ease;
        white-space: nowrap;
    }
    .nav-link:hover { opacity: 1; background-color: rgb(var(--ink) / 0.05); }

    .nav-link.active {
        opacity: 1;
        background-color: rgb(var(--ink) / 0.06);
    }
    .nav-link.active::after {
        content: "";
        position: absolute;
        left: 0.7rem;
        right: 0.7rem;
        bottom: 0.15rem;
        height: 3px;
        background-image: linear-gradient(90deg, currentColor 50%, transparent 50%);
        background-size: 8px 2px;
        background-repeat: repeat-x;
        opacity: 0.6;
    }

    .accent-link { color: rgb(var(--chocolate)); opacity: 0.95; }
    .accent-link:hover { opacity: 1; }
</style>

@code {
    [Parameter] public EventCallback OnMobileToggle { get; set; }

    private const string LinkBase = "nav-link";

    private readonly (string Href, string Label, string? Glyph, bool Accent)[] _items =
    [
        ("",          "Storefront", null,            false),
        ("orders",    "Orders",     null,            false),
        ("inventory", "Inventory",  null,            false),
        ("production","Production", null,            false),
        ("warehouse", "Warehouse",  null,            false),
        ("recipes",   "Recipes",    null,            false),
        ("recipe-manager", "Recipe Manager", null,   false),
        ("loyalty",   "Loyalty",    null,            false),
        ("supplier",  "Supplier",   null,            false),
        ("agents",    "Agents",     "deco-sparkle",  true),
    ];

    private async Task HandleMobileToggle()
    {
        if (OnMobileToggle.HasDelegate) await OnMobileToggle.InvokeAsync();
    }
}
