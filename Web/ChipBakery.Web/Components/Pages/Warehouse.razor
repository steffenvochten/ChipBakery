@page "/warehouse"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient
@implements IDisposable

<PageTitle>Warehouse · ChipBakery</PageTitle>

<div class="space-y-10 animate-fade-up">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <SectionHeader Eyebrow="the pantry"
                       Subtitle="Raw ingredients on hand. Restock from the supplier when a sack runs low.">
            Warehouse
        </SectionHeader>
        <PaperButton Variant="ButtonVariant.Chocolate"
                     Glyph="glyph-plus"
                     OnClick="OpenAddModal">
            Add ingredient
        </PaperButton>
    </div>

    @if (_isLoading)
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @for (int i = 0; i < 6; i++)
            {
                <Skeleton Variant="Skeleton.SkeletonVariant.Card" />
            }
        </div>
    }
    else if (_items.Count == 0)
    {
        <PaperCard>
            <EmptyState Doodle="utensil-bowl" Headline="The pantry's empty">
                <ChildContent>Add your first raw ingredient to start tracking warehouse stock.</ChildContent>
                <Action>
                    <PaperButton Glyph="glyph-plus" OnClick="OpenAddModal">Add ingredient</PaperButton>
                </Action>
            </EmptyState>
        </PaperCard>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var item in _items)
            {
                <PaperCard RotateKey="@item.Id"
                           Tape="@TapeFor(item)"
                           Hoverable="true">
                    <div class="flex items-start justify-between mb-3">
                        <div class="min-w-0">
                            <div class="display-hand text-lg text-kraft leading-none mb-1">ingredient</div>
                            <h3 class="font-serif font-bold text-xl text-ink truncate">@item.Name</h3>
                        </div>
                        <Doodle Name="@DoodleFor(item)" Class="w-8 h-8 text-chocolate flex-shrink-0" />
                    </div>
                    <div class="flex items-baseline gap-2 mt-4">
                        <span class="font-mono font-bold text-3xl sm:text-4xl text-chocolate">
                            @item.Quantity.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)
                        </span>
                        <span class="font-mono text-sm uppercase tracking-widest text-ink-muted">@item.Unit</span>
                    </div>
                    <div class="mt-5 pt-3 border-t flex" style="border-color: rgb(var(--ink) / 0.08);">
                        <PaperButton Variant="ButtonVariant.Outline"
                                     Size="BakerySize.Sm"
                                     Glyph="glyph-plus"
                                     Class="w-full justify-center"
                                     OnClick="() => OpenRestock(item)">
                            Restock
                        </PaperButton>
                    </div>
                </PaperCard>
            }
        </div>
    }
</div>

<RecipeModal @bind-Open="_addOpen"
             Title="Add ingredient"
             Eyebrow="new sack"
             Size="Md">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_addError))
        {
            <div class="mb-4 px-4 py-3 rounded-2xl text-sm font-bold"
                 style="background-color: rgb(var(--raspberry) / 0.12); color: rgb(var(--raspberry));"
                 role="alert">@_addError</div>
        }
        <div class="space-y-4">
            <FormField Label="Name" Required="true">
                <input class="form-control" placeholder="e.g. Bread flour" @bind="_newItem.Name" />
            </FormField>
            <div class="grid grid-cols-2 gap-3">
                <FormField Label="Quantity">
                    <input class="form-control font-mono" type="number" step="0.01" min="0" @bind="_newItem.Quantity" />
                </FormField>
                <FormField Label="Unit">
                    <input class="form-control" placeholder="kg, L, units" @bind="_newItem.Unit" />
                </FormField>
            </div>
        </div>
    </ChildContent>
    <Footer>
        <PaperButton Variant="ButtonVariant.Ghost" OnClick="() => _addOpen = false" Disabled="@_isSaving">Cancel</PaperButton>
        <PaperButton Variant="ButtonVariant.Chocolate" Loading="@_isSaving" OnClick="SaveNew">Add ingredient</PaperButton>
    </Footer>
</RecipeModal>

<RecipeModal @bind-Open="_restockOpen"
             Title="@($"Restock {_restockTarget?.Name}")"
             Eyebrow="dispatch supplier"
             Size="Sm">
    <ChildContent>
        @if (_restockTarget is not null)
        {
            @if (!string.IsNullOrEmpty(_restockError))
            {
                <div class="mb-4 px-4 py-3 rounded-2xl text-sm font-bold"
                     style="background-color: rgb(var(--raspberry) / 0.12); color: rgb(var(--raspberry));"
                     role="alert">@_restockError</div>
            }
            <FormField Label="@($"Quantity ({_restockTarget.Unit})")" Hint="Will arrive via the supplier service.">
                <input class="form-control font-mono" type="number" step="0.01" min="0" @bind="_restockQuantity" />
            </FormField>
        }
    </ChildContent>
    <Footer>
        <PaperButton Variant="ButtonVariant.Ghost" OnClick="() => _restockOpen = false" Disabled="@_isRestocking">Cancel</PaperButton>
        <PaperButton Variant="ButtonVariant.Chocolate" Loading="@_isRestocking" OnClick="ConfirmRestock">Dispatch</PaperButton>
    </Footer>
</RecipeModal>

<Toast @bind-Message="_toast" Variant="@_toastVariant" />

@code {
    private List<WarehouseItem> _items = new();
    private bool _isLoading = true;

    private bool _addOpen;
    private CreateWarehouseItemRequest _newItem = new();
    private bool _isSaving;
    private string? _addError;

    private bool _restockOpen;
    private WarehouseItem? _restockTarget;
    private decimal _restockQuantity = 50m;
    private bool _isRestocking;
    private string? _restockError;

    private string? _toast;
    private Toast.ToastVariant _toastVariant = Toast.ToastVariant.Success;

    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        }), null, 2000, 2000);
    }

    public void Dispose() => _timer?.Dispose();

    private async Task LoadData()
    {
        try
        {
            _items = await ApiClient.GetAllWarehouseItemsAsync();
        }
        catch (Exception ex)
        {
            ShowToast($"Failed to load warehouse: {ex.Message}", Toast.ToastVariant.Error);
            _items = new();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenAddModal()
    {
        _addError = null;
        _newItem  = new CreateWarehouseItemRequest();
        _addOpen  = true;
    }

    private async Task SaveNew()
    {
        if (_isSaving) return;
        if (string.IsNullOrWhiteSpace(_newItem.Name))
        {
            _addError = "Name is required.";
            return;
        }

        _isSaving = true;
        _addError = null;
        try
        {
            var success = await ApiClient.CreateWarehouseItemAsync(_newItem);
            if (!success)
            {
                _addError = "Failed to save ingredient.";
                return;
            }
            await LoadData();
            _addOpen = false;
            ShowToast("Ingredient added.", Toast.ToastVariant.Success);
        }
        catch (Exception ex)
        {
            _addError = $"Save failed: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void OpenRestock(WarehouseItem item)
    {
        _restockTarget   = item;
        _restockQuantity = 50m;
        _restockError    = null;
        _restockOpen     = true;
    }

    private async Task ConfirmRestock()
    {
        if (_restockTarget is null || _isRestocking) return;
        if (_restockQuantity <= 0)
        {
            _restockError = "Quantity must be greater than 0.";
            return;
        }

        _isRestocking = true;
        _restockError = null;
        try
        {
            var req = new RestockRequest(_restockTarget.Name, _restockQuantity, _restockTarget.Unit);
            await ApiClient.DispatchRestockAsync(req);
            var name = _restockTarget.Name;
            _restockOpen   = false;
            _restockTarget = null;
            await LoadData();
            ShowToast($"Restock dispatched for {name}.", Toast.ToastVariant.Success);
        }
        catch (Exception ex)
        {
            _restockError = $"Restock failed: {ex.Message}";
        }
        finally
        {
            _isRestocking = false;
        }
    }

    private void ShowToast(string msg, Toast.ToastVariant variant)
    {
        _toastVariant = variant;
        _toast = msg;
    }

    private TapeColor TapeFor(WarehouseItem item)
    {
        return item.Quantity switch
        {
            <= 5    => TapeColor.Raspberry,
            <= 20   => TapeColor.Lemon,
            _       => TapeColor.Default,
        };
    }

    private string DoodleFor(WarehouseItem item)
    {
        var name = item.Name?.ToLowerInvariant() ?? "";
        if (name.Contains("flour") || name.Contains("sugar") || name.Contains("salt")) return "utensil-scale";
        if (name.Contains("milk") || name.Contains("cream") || name.Contains("water")) return "utensil-bowl";
        if (name.Contains("butter") || name.Contains("oil") || name.Contains("egg"))   return "utensil-whisk";
        if (name.Contains("yeast") || name.Contains("starter"))                         return "deco-wheat";
        return "deco-wheat";
    }
}
