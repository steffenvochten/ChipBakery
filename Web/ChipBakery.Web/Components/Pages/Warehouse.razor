@page "/warehouse"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient
@implements IDisposable

<PageTitle>Warehouse - Chip Bakery</PageTitle>

<div class="space-y-8 animate-in fade-in duration-700">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-bakery-crust dark:text-amber-400">
                Warehouse
            </h1>
            <p class="text-lg text-bakery-crust/60 dark:text-stone-400 font-medium">
                Manage raw materials and ingredients.
            </p>
        </div>
        <button @onclick="OpenAddModal" class="btn btn-primary self-start sm:self-center shadow-bakery-crust/20">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add Ingredient
        </button>
    </div>

    @if (!string.IsNullOrEmpty(pageMessage))
    {
        <div class="rounded-3xl @(pageIsError ? "bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 border-red-300/50" : "bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border-green-300/50") border p-4 font-bold flex items-center justify-between gap-4">
            <span>@pageMessage</span>
            <button class="btn btn-outline py-2 text-xs" @onclick="() => pageMessage = null">Dismiss</button>
        </div>
    }

    @if (isLoading)
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var i in Enumerable.Range(0, 6))
            {
                <div class="glass-card p-6 space-y-4 animate-pulse">
                    <div class="h-6 w-1/2 bg-bakery-crust/10 dark:bg-stone-800 rounded-lg"></div>
                    <div class="h-10 w-full bg-bakery-crust/5 dark:bg-stone-800/50 rounded-xl"></div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var item in warehouseItems)
            {
                <div class="glass-card p-6 flex flex-col justify-between hover:-translate-y-1 transition-transform duration-300">
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <h3 class="text-xl font-bold text-bakery-crust dark:text-stone-100">@item.Name</h3>
                            <span class="text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500">@item.Unit</span>
                        </div>
                        <div class="text-3xl font-black text-amber-700 dark:text-amber-500">
                            @item.Quantity.ToString("N2")
                        </div>
                    </div>
                    <div class="mt-6 pt-4 border-t border-bakery-crust/5 flex gap-2">
                        <button class="btn btn-outline py-2 flex-1 text-xs" @onclick="() => RestockItem(item)">Restock</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showAddModal)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center p-4 sm:p-6 backdrop-blur-md bg-stone-950/40 animate-in fade-in duration-300">
        <div class="glass-card w-full max-w-md p-8 shadow-2xl bg-white/90 dark:bg-stone-900/90">
            <h2 class="text-2xl font-black text-bakery-crust dark:text-amber-400 mb-6">Add New Ingredient</h2>

            @if (!string.IsNullOrEmpty(addError))
            {
                <div class="mb-4 px-4 py-3 rounded-2xl bg-red-100 text-red-700 text-sm font-bold">@addError</div>
            }

            <div class="space-y-4">
                <div>
                    <label class="form-label">Ingredient Name</label>
                    <input @bind="newItem.Name" type="text" class="form-control" placeholder="e.g. Bread Flour" />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="form-label">Quantity</label>
                        <input @bind="newItem.Quantity" type="number" class="form-control" />
                    </div>
                    <div>
                        <label class="form-label">Unit</label>
                        <input @bind="newItem.Unit" type="text" class="form-control" placeholder="kg, L, etc." />
                    </div>
                </div>
            </div>

            <div class="flex gap-3 mt-8">
                <button @onclick="CloseAddModal" class="btn btn-outline flex-1" disabled="@isSaving">Cancel</button>
                <button @onclick="SaveItem" class="btn btn-primary flex-1" disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Save Ingredient")
                </button>
            </div>
        </div>
    </div>
}

@if (restockTarget != null)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center p-4 sm:p-6 backdrop-blur-md bg-stone-950/40 animate-in fade-in duration-300">
        <div class="glass-card w-full max-w-md p-8 shadow-2xl bg-white/90 dark:bg-stone-900/90">
            <span class="text-xs font-black uppercase tracking-widest text-bakery-crust dark:text-amber-500 block">Restock</span>
            <h2 class="text-2xl font-black text-bakery-crust dark:text-amber-400 mb-6">@restockTarget.Name</h2>

            @if (!string.IsNullOrEmpty(restockError))
            {
                <div class="mb-4 px-4 py-3 rounded-2xl bg-red-100 text-red-700 text-sm font-bold">@restockError</div>
            }

            <div>
                <label class="form-label">Quantity (@restockTarget.Unit)</label>
                <input @bind="restockQuantity" type="number" step="0.01" min="0" class="form-control" />
            </div>

            <div class="flex gap-3 mt-8">
                <button @onclick="CancelRestock" class="btn btn-outline flex-1" disabled="@isRestocking">Cancel</button>
                <button @onclick="ConfirmRestock" class="btn btn-primary flex-1" disabled="@isRestocking">
                    @(isRestocking ? "Dispatching..." : "Confirm Restock")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<WarehouseItem> warehouseItems = new();
    private bool isLoading = true;
    private bool showAddModal = false;
    private CreateWarehouseItemRequest newItem = new();
    private bool isSaving = false;
    private string? addError;
    private string? pageMessage;
    private bool pageIsError;

    private WarehouseItem? restockTarget;
    private decimal restockQuantity = 50m;
    private bool isRestocking = false;
    private string? restockError;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        }), null, 2000, 2000);
    }

    private async Task LoadData()
    {
        try
        {
            warehouseItems = await ApiClient.GetAllWarehouseItemsAsync();
        }
        catch (Exception ex)
        {
            ShowMessage($"Failed to load warehouse: {ex.Message}", true);
            warehouseItems = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    public void Dispose() => _timer?.Dispose();

    private void OpenAddModal()
    {
        addError = null;
        showAddModal = true;
    }

    private void CloseAddModal() => showAddModal = false;

    private async Task SaveItem()
    {
        if (isSaving) return;
        if (string.IsNullOrWhiteSpace(newItem.Name))
        {
            addError = "Name is required.";
            return;
        }

        isSaving = true;
        addError = null;
        try
        {
            var success = await ApiClient.CreateWarehouseItemAsync(newItem);
            if (!success)
            {
                addError = "Failed to save ingredient.";
                return;
            }
            await LoadData();
            showAddModal = false;
            newItem = new();
            ShowMessage("Ingredient saved.", false);
        }
        catch (Exception ex)
        {
            addError = $"Save failed: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void RestockItem(WarehouseItem item)
    {
        restockTarget = item;
        restockQuantity = 50m;
        restockError = null;
    }

    private void CancelRestock()
    {
        restockTarget = null;
        restockError = null;
    }

    private async Task ConfirmRestock()
    {
        if (restockTarget is null || isRestocking) return;
        if (restockQuantity <= 0)
        {
            restockError = "Quantity must be greater than 0.";
            return;
        }

        isRestocking = true;
        restockError = null;
        try
        {
            var req = new RestockRequest(restockTarget.Name, restockQuantity, restockTarget.Unit);
            await ApiClient.DispatchRestockAsync(req);
            var name = restockTarget.Name;
            restockTarget = null;
            await LoadData();
            ShowMessage($"Restock dispatched for {name}.", false);
        }
        catch (Exception ex)
        {
            restockError = $"Restock failed: {ex.Message}";
        }
        finally
        {
            isRestocking = false;
        }
    }

    private void ShowMessage(string msg, bool isError)
    {
        pageMessage = msg;
        pageIsError = isError;
    }
}
