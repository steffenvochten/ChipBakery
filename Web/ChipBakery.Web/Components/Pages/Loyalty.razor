@page "/loyalty"
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient

<PageTitle>Loyalty · ChipBakery</PageTitle>

<div class="space-y-10 animate-fade-up">
    <SectionHeader Eyebrow="for our regulars" Subtitle="@_subtitle">
        Loyalty rewards
    </SectionHeader>

    <PaperCard Class="max-w-2xl" Tape="TapeColor.Lemon">
        <FormField Label="Customer ID" For="cust-id" Hint="Paste the GUID from your order receipt.">
            <div class="flex flex-col sm:flex-row gap-3">
                <div class="relative flex-1">
                    <input id="cust-id"
                           class="form-control pl-10"
                           placeholder="00000000-0000-0000-0000-000000000000"
                           @bind="_searchId"
                           @bind:event="oninput"
                           @onkeyup="HandleKeyUp" />
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-ink-muted opacity-60">
                        <Doodle Name="glyph-search" Class="w-5 h-5" ViewBox="0 0 24 24" />
                    </span>
                </div>
                <PaperButton Variant="ButtonVariant.Chocolate"
                             OnClick="Lookup"
                             Loading="@_isSearching"
                             Disabled="@(_isSearching || string.IsNullOrWhiteSpace(_searchId))">
                    Look up
                </PaperButton>
            </div>
        </FormField>

        <div class="mt-8">
            @if (_isSearching)
            {
                <Skeleton Variant="Skeleton.SkeletonVariant.Card" />
            }
            else if (_loyalty is not null)
            {
                <div class="animate-fade-up space-y-8">
                    @* ---- Tier punch card ---- *@
                    <div class="relative rounded-3xl p-7 overflow-hidden"
                         style="background: linear-gradient(135deg, rgb(var(--chocolate)) 0%, rgb(var(--kraft) / 0.85) 100%); color: rgb(var(--paper));">
                        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 relative z-10">
                            <div>
                                <div class="display-hand text-2xl opacity-80 leading-none mb-1">currently</div>
                                <div class="font-serif font-bold text-4xl tracking-tight">@_loyalty.Tier</div>
                            </div>
                            <div class="text-left sm:text-right">
                                <div class="display-hand text-xl opacity-80 leading-none mb-1">total stamps</div>
                                <div class="font-mono font-bold text-5xl sm:text-6xl tracking-tight">@_loyalty.TotalPoints</div>
                            </div>
                        </div>
                        @* Subtle stamp pattern dots *@
                        <div class="absolute inset-0 opacity-10 pointer-events-none"
                             style="background-image: radial-gradient(circle, rgb(var(--paper)) 2px, transparent 2px); background-size: 28px 28px;"></div>
                    </div>

                    @* ---- Transactions ---- *@
                    <div>
                        <div class="flex items-baseline justify-between mb-4">
                            <h3 class="font-serif font-bold text-xl text-ink">Recent stamps</h3>
                            <span class="text-xs text-ink-muted">@_loyalty.Transactions.Count entries</span>
                        </div>
                        @if (_loyalty.Transactions.Count == 0)
                        {
                            <EmptyState Doodle="doodle-cookie" Headline="No stamps yet" Size="BakerySize.Sm">
                                Place an order to earn your first reward.
                            </EmptyState>
                        }
                        else
                        {
                            <div class="space-y-2.5">
                                @foreach (var tx in _loyalty.Transactions)
                                {
                                    <div class="flex items-center justify-between gap-4 px-4 py-3 rounded-2xl"
                                         style="background-color: rgb(var(--ink) / 0.04); border: 1px dashed rgb(var(--ink) / 0.12);">
                                        <div class="flex items-center gap-3 min-w-0">
                                            <Doodle Name="@(tx.Points >= 0 ? "deco-sparkle" : "glyph-x")"
                                                    Class="@($"w-5 h-5 flex-shrink-0 {(tx.Points >= 0 ? "text-basil" : "text-raspberry")}")"
                                                    ViewBox="@(tx.Points >= 0 ? "0 0 32 32" : "0 0 24 24")" />
                                            <div class="min-w-0">
                                                <div class="font-bold text-ink truncate">@tx.Description</div>
                                                <div class="text-xs text-ink-muted font-mono">@tx.Date.ToLocalTime().ToString("MMM dd, yyyy · HH:mm")</div>
                                            </div>
                                        </div>
                                        <div class="@($"font-mono font-bold text-lg flex-shrink-0 {(tx.Points >= 0 ? "text-basil" : "text-raspberry")}")">
                                            @(tx.Points >= 0 ? "+" : "")@tx.Points
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else if (_hasSearched && _notFound)
            {
                <EmptyState Doodle="doodle-cookie" Headline="No customer found">
                    Double-check the ID, or place an order to join the rewards programme.
                </EmptyState>
            }
        </div>
    </PaperCard>
</div>

<Toast @bind-Message="_toast" Variant="Toast.ToastVariant.Error" />

@code {
    private string _searchId = "";
    private bool _isSearching;
    private bool _hasSearched;
    private bool _notFound;
    private string? _toast;
    private CustomerLoyalty? _loyalty;

    private static readonly string _subtitle =
        "Find your stamps, see your tier, and watch the rewards rise loaf by loaf.";

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Lookup();
    }

    private async Task Lookup()
    {
        if (!Guid.TryParse(_searchId, out var customerId))
        {
            _toast = "That doesn't look like a valid customer ID.";
            return;
        }

        _isSearching = true;
        _hasSearched = true;
        _notFound = false;
        _toast = null;
        _loyalty = null;

        try
        {
            _loyalty = await ApiClient.GetCustomerLoyaltyAsync(customerId);
            if (_loyalty is null) _notFound = true;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _notFound = true;
        }
        catch (Exception)
        {
            _toast = "We couldn't reach the loyalty service. Try again in a moment.";
        }
        finally
        {
            _isSearching = false;
        }
    }
}
