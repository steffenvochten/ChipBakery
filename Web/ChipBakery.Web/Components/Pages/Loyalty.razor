@page "/loyalty"
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient

<PageTitle>Loyalty - Chip Bakery</PageTitle>

<div class="space-y-8 animate-in fade-in duration-700">
    <div>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-bakery-crust dark:text-amber-400">
            Loyalty Rewards
        </h1>
        <p class="text-lg text-bakery-crust/60 dark:text-stone-400 font-medium">
            Track your points and artisanal rewards.
        </p>
    </div>

    <div class="glass-card p-8 max-w-2xl">
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <div class="flex-1">
                <label class="form-label">Customer ID</label>
                <div class="relative">
                    <input @bind="searchId" @bind:event="oninput" @onkeyup="HandleKeyUp" type="text" class="form-control pl-10" placeholder="Enter your ID..." />
                    <svg class="w-5 h-5 absolute left-3 top-1/2 -translate-y-1/2 text-bakery-crust/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
            </div>
            <button @onclick="Lookup" class="btn btn-primary self-end h-[46px] px-8">Lookup</button>
        </div>

        @if (isSearching)
        {
            <div class="animate-pulse space-y-6">
                <div class="h-24 w-full bg-bakery-crust/5 dark:bg-stone-800 rounded-2xl"></div>
                <div class="h-64 w-full bg-bakery-crust/5 dark:bg-stone-800 rounded-2xl"></div>
            </div>
        }
        else if (loyalty != null)
        {
            <div class="space-y-8 animate-in slide-in-from-bottom-4 duration-500">
                <div class="p-6 rounded-2xl bg-gradient-to-br from-bakery-dough to-amber-200/50 dark:from-stone-900 dark:to-stone-800 border border-bakery-crust/10">
                    <div class="flex justify-between items-start">
                        <div>
                            <p class="text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500 mb-1">Current Tier</p>
                            <h2 class="text-3xl font-black text-bakery-crust dark:text-amber-400">@loyalty.Tier</h2>
                        </div>
                        <div class="text-right">
                            <p class="text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500 mb-1">Total Points</p>
                            <p class="text-5xl font-black text-amber-700 dark:text-amber-500 tracking-tighter">@loyalty.TotalPoints</p>
                        </div>
                    </div>
                </div>

                <div>
                    <h3 class="text-xl font-bold text-bakery-crust dark:text-stone-100 mb-4">Recent Transactions</h3>
                    <div class="space-y-3">
                        @foreach (var tx in loyalty.Transactions)
                        {
                            <div class="flex items-center justify-between p-4 rounded-xl bg-bakery-crust/5 dark:bg-stone-800/40 border border-bakery-crust/5">
                                <div>
                                    <p class="font-bold text-bakery-crust dark:text-stone-200">@tx.Description</p>
                                    <p class="text-xs text-stone-500">@tx.Date.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</p>
                                </div>
                                <div class="text-lg font-black @(tx.Points >= 0 ? "text-green-500" : "text-red-500")">
                                    @(tx.Points >= 0 ? "+" : "")@tx.Points
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else if (hasSearched)
        {
            <div class="p-12 text-center opacity-50">
                <p class="text-xl font-bold">Customer not found.</p>
                <p class="text-sm">Try another ID or place an order to join!</p>
            </div>
        }
    </div>
</div>

@code {
    private string searchId = "";
    private bool isSearching = false;
    private bool hasSearched = false;
    private CustomerLoyalty? loyalty;

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Lookup();
    }

    private async Task Lookup()
    {
        if (!Guid.TryParse(searchId, out var customerId)) return;

        isSearching = true;
        hasSearched = true;
        loyalty = await ApiClient.GetCustomerLoyaltyAsync(customerId);
        isSearching = false;
    }
}
