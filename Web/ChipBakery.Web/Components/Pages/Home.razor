@page "/"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient
@implements IDisposable

<PageTitle>ChipBakery · fresh from the oven</PageTitle>

@* ===========================================================
   Hero — chalkboard menu board with hand-lettered headline
   =========================================================== *@
<section class="relative chalkboard-surface overflow-hidden p-8 sm:p-14 mb-14 shadow-deep">
    <div class="relative z-10 max-w-2xl">
        <div class="display-hand text-3xl sm:text-4xl text-lemon mb-2 leading-none">today's specials</div>
        <h1 class="font-serif font-bold text-5xl sm:text-7xl text-paper leading-[0.95] tracking-tight mb-6">
            Fresh from <br />
            <span class="display-hand text-lemon" style="font-size:1.05em;">the oven.</span>
        </h1>
        <p class="text-paper/85 text-lg max-w-xl mb-8 leading-relaxed">
            Baked this morning, sold by sundown. Pick a pastry, place an order — we'll keep one warm.
        </p>
        <div class="flex flex-wrap items-center gap-4">
            <PaperButton Href="#menu"
                         Variant="ButtonVariant.Kraft"
                         Glyph="glyph-arrow-right"
                         TrailingGlyph="true">
                Browse the menu
            </PaperButton>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-2xl"
                 style="background-color: rgb(var(--paper) / 0.12); color: rgb(var(--paper));">
                <span class="flex h-2 w-2 rounded-full bg-basil animate-pulse" aria-hidden="true"></span>
                <span class="text-xs font-bold uppercase tracking-widest">Open for orders</span>
            </div>
        </div>
    </div>

    @* Decorative doodles in the corners *@
    <div class="absolute top-6 right-8 opacity-15 hidden sm:block text-paper" aria-hidden="true">
        <Doodle Name="doodle-croissant" Class="w-32 h-32" />
    </div>
    <div class="absolute -bottom-6 right-1/3 opacity-10 hidden md:block text-paper" aria-hidden="true">
        <Doodle Name="utensil-rolling-pin" Class="w-40 h-40" />
    </div>
</section>

@* ===========================================================
   Today's menu grid
   =========================================================== *@
<section id="menu" class="space-y-8 scroll-mt-24">
    <SectionHeader Eyebrow="today's"
                   Subtitle="Fresh out of the oven this morning. When it's gone, it's gone.">
        Menu
    </SectionHeader>

    @if (_isLoading)
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            @for (int i = 0; i < 3; i++) { <Skeleton Variant="Skeleton.SkeletonVariant.Card" /> }
        </div>
    }
    else if (_products is null || _products.Count == 0)
    {
        <PaperCard>
            <EmptyState Doodle="doodle-cookie" Headline="Looks like we're sold out!" Size="BakerySize.Lg">
                Check back tomorrow for fresh-baked pastries straight from the oven.
            </EmptyState>
        </PaperCard>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var product in _products)
            {
                <PaperCard RotateKey="@product.Id"
                           Tape="@TapeFor(product)"
                           Hoverable="true"
                           Padding="p-0"
                           Class="overflow-hidden flex flex-col group">
                    <div class="relative aspect-square overflow-hidden"
                         style="background-color: rgb(var(--paper));">
                        <img src="@GetImageForProduct(product.Name)"
                             alt="@product.Name"
                             loading="lazy"
                             class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />

                        @* Kraft price tag in the top-right *@
                        <div class="absolute top-4 right-4">
                            <Sticker RotateKey="@product.Id"
                                     Class="px-3 py-1.5 rounded-2xl"
                                     style="background-color: rgb(var(--kraft)); color: rgb(var(--paper));">
                                <span class="font-mono font-bold text-base">€@product.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)</span>
                            </Sticker>
                        </div>
                    </div>

                    <div class="p-6 flex-1 flex flex-col gap-4">
                        <h3 class="font-serif font-bold text-xl text-ink group-hover:text-chocolate transition-colors">
                            @product.Name
                        </h3>

                        <div class="mt-auto flex items-center justify-between gap-3">
                            @if (product.AvailableQuantity > 0)
                            {
                                <span class="text-xs font-bold text-ink-muted uppercase tracking-widest">
                                    <span class="inline-block w-2 h-2 rounded-full bg-basil mr-1.5" aria-hidden="true"></span>
                                    @product.AvailableQuantity left
                                </span>
                                <PaperButton Variant="ButtonVariant.Chocolate"
                                             Size="BakerySize.Sm"
                                             OnClick="() => OpenOrderModal(product)">
                                    Order
                                </PaperButton>
                            }
                            else
                            {
                                <StatusBadge Status="BakeryStatus.OutOfStock" RotateKey="@product.Id" />
                                <PaperButton Variant="ButtonVariant.Outline"
                                             Size="BakerySize.Sm"
                                             Disabled="true">
                                    Sold out
                                </PaperButton>
                            }
                        </div>
                    </div>
                </PaperCard>
            }
        </div>
    }
</section>

@* ===========================================================
   Order modal
   =========================================================== *@
<RecipeModal @bind-Open="_isOrderOpen"
             Title="@(_selectedProduct?.Name ?? "Order")"
             Eyebrow="place an order"
             Size="Md">
    <ChildContent>
        @if (_selectedProduct is not null)
        {
            <EditForm Model="_orderModel" OnValidSubmit="PlaceOrder">
                <div class="space-y-5">
                    <FormField Label="Your name" For="customer-name" Required="true">
                        <InputText id="customer-name"
                                   class="form-control"
                                   @bind-Value="_orderModel.CustomerName"
                                   placeholder="e.g. Maria" />
                    </FormField>

                    <FormField Label="Quantity">
                        <NumberStepper @bind-Value="_orderModel.Quantity"
                                       Min="1"
                                       Max="@Math.Max(1, _selectedProduct.AvailableQuantity)" />
                    </FormField>

                    @* Receipt-style total *@
                    <div class="rounded-2xl px-5 py-4 flex items-center justify-between gap-4"
                         style="background-color: rgb(var(--paper)); border: 2px dashed rgb(var(--ink) / 0.3);">
                        <div>
                            <div class="display-hand text-base text-kraft leading-none mb-1">total</div>
                            <div class="text-xs text-ink-muted font-mono">
                                @_orderModel.Quantity × €@_selectedProduct.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)
                            </div>
                        </div>
                        <div class="font-mono font-bold text-3xl text-chocolate">
                            €@((_orderModel.Quantity * _selectedProduct.Price).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))
                        </div>
                    </div>
                </div>
            </EditForm>
        }
    </ChildContent>
    <Footer>
        <PaperButton Variant="ButtonVariant.Ghost" OnClick="CloseOrderModal" Disabled="@_isOrdering">Cancel</PaperButton>
        <PaperButton Variant="ButtonVariant.Chocolate"
                     Loading="@_isOrdering"
                     Glyph="glyph-check"
                     OnClick="PlaceOrder">
            Confirm order
        </PaperButton>
    </Footer>
</RecipeModal>

<Toast @bind-Message="_toast" Variant="@_toastVariant" Duration="4000" />

@code {
    private List<ProductItem>? _products;
    private bool _isLoading = true;
    private System.Threading.Timer? _timer;

    private bool _isOrderOpen;
    private ProductItem? _selectedProduct;
    private OrderModel _orderModel = new();
    private bool _isOrdering;

    private string? _toast;
    private Toast.ToastVariant _toastVariant = Toast.ToastVariant.Success;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(async () =>
        {
            await LoadProducts();
            StateHasChanged();
        }), null, 2000, 2000);
    }

    public void Dispose() => _timer?.Dispose();

    private async Task LoadProducts()
    {
        try
        {
            _products = await ApiClient.GetAvailableProductsAsync();
        }
        catch (Exception)
        {
            ShowToast("Failed to load products.", Toast.ToastVariant.Error);
            _products = new();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetImageForProduct(string name)
    {
        if (name.Contains("Croissant", StringComparison.OrdinalIgnoreCase)) return "/images/butter_croissant.png";
        if (name.Contains("Sourdough", StringComparison.OrdinalIgnoreCase)) return "/images/sourdough_loaf.png";
        if (name.Contains("Eclair") || name.Contains("Éclair", StringComparison.OrdinalIgnoreCase)) return "/images/chocolate_eclair.png";
        return "/images/placeholder_pastry.png";
    }

    private TapeColor TapeFor(ProductItem p)
    {
        // Stable tape colour per product; cycles by id hash.
        var seed = BakeryRandom.RotationSeed(p.Id);
        return seed switch
        {
            0 or 4 => TapeColor.Lemon,
            1 or 5 => TapeColor.Basil,
            2      => TapeColor.Raspberry,
            _      => TapeColor.Kraft,
        };
    }

    private void OpenOrderModal(ProductItem product)
    {
        _selectedProduct = product;
        _orderModel      = new OrderModel { Quantity = 1 };
        _isOrderOpen     = true;
    }

    private void CloseOrderModal() => _isOrderOpen = false;

    private async Task PlaceOrder()
    {
        if (_selectedProduct is null || _isOrdering) return;
        if (string.IsNullOrWhiteSpace(_orderModel.CustomerName))
        {
            ShowToast("Add a name for the order.", Toast.ToastVariant.Error);
            return;
        }

        _isOrdering = true;
        try
        {
            var request = new OrderRequest(
                _selectedProduct.Id,
                _orderModel.Quantity,
                _orderModel.CustomerName,
                Guid.NewGuid().ToString());

            var response = await ApiClient.PlaceOrderAsync(request);
            ShowToast(response.Message, response.Success ? Toast.ToastVariant.Success : Toast.ToastVariant.Error);

            if (response.Success)
            {
                CloseOrderModal();
                await LoadProducts();
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Order failed: {ex.Message}", Toast.ToastVariant.Error);
        }
        finally
        {
            _isOrdering = false;
        }
    }

    private void ShowToast(string msg, Toast.ToastVariant variant)
    {
        _toastVariant = variant;
        _toast = msg;
    }

    private class OrderModel
    {
        public string CustomerName { get; set; } = "";
        public int    Quantity     { get; set; } = 1;
    }
}
