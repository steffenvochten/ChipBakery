@page "/"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient

<PageTitle>Chip Bakery | Artisanal Excellence</PageTitle>

<div class="relative overflow-hidden rounded-4xl bg-gradient-to-br from-bakery-dough to-amber-200/50 dark:from-stone-900 dark:to-stone-800 p-8 sm:p-16 mb-12 shadow-sm">
    <div class="relative z-10 max-w-2xl">
        <h1 class="text-5xl sm:text-7xl font-serif font-black text-bakery-crust dark:text-amber-500 mb-6 tracking-tight leading-none">
            Fresh From <br/><span class="text-stone-900 dark:text-stone-100">The Oven.</span>
        </h1>
        <p class="text-xl text-stone-700 dark:text-stone-300 font-medium mb-8 leading-relaxed">
            Artisanal breads and pastries, baked daily with passion and the finest ingredients.
        </p>
        <div class="flex flex-wrap gap-4">
            <a href="#menu" class="btn btn-primary px-8">Browse Menu</a>
            <div class="flex items-center gap-2 px-4 py-2 bg-white/40 dark:bg-stone-800/40 backdrop-blur-sm rounded-2xl border border-white/20">
                <span class="flex h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
                <span class="text-xs font-bold uppercase tracking-widest opacity-70">Open for Orders</span>
            </div>
        </div>
    </div>
    <!-- Subtle illustrative element (placeholder) -->
    <div class="absolute -bottom-10 -right-10 w-64 h-64 bg-amber-300/20 dark:bg-amber-500/10 rounded-full blur-3xl"></div>
</div>

<section id="menu" class="space-y-8">
    <div class="flex items-end justify-between px-2">
        <div>
            <h2 class="text-3xl font-serif font-black text-bakery-crust dark:text-amber-500">Today's Menu</h2>
            <p class="text-stone-500 font-medium">Baked fresh this morning.</p>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            @for(int i=0; i<3; i++) {
                <div class="glass-card h-96 animate-pulse"></div>
            }
        </div>
    }
    else if (_products == null || !_products.Any())
    {
        <div class="glass-card p-16 text-center">
            <div class="text-6xl mb-6">🥐</div>
            <h3 class="text-2xl font-serif font-black mb-2">Looks like we're sold out!</h3>
            <p class="text-stone-500">Check back tomorrow for fresh bakes.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var product in _products)
            {
                <div class="glass-card group hover:shadow-xl hover:-translate-y-1 transition-all duration-500 overflow-hidden flex flex-col">
                    <div class="aspect-square relative overflow-hidden bg-stone-100 dark:bg-stone-800">
                        <img src="@GetImageForProduct(product.Name)" alt="@product.Name" 
                             class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                        <div class="absolute top-4 right-4">
                            <span class="px-3 py-1 bg-white/90 dark:bg-stone-900/90 backdrop-blur-sm rounded-full text-xs font-black shadow-sm">
                                $@product.Price.ToString("0.00")
                            </span>
                        </div>
                    </div>
                    <div class="p-6 flex-1 flex flex-col">
                        <h3 class="text-xl font-serif font-black mb-4 group-hover:text-bakery-crust dark:group-hover:text-amber-500 transition-colors">@product.Name</h3>
                        
                        <div class="mt-auto flex items-center justify-between gap-4">
                            @if(product.AvailableQuantity > 0)
                            {
                                <span class="text-xs font-bold text-stone-500">
                                    <span class="text-green-500 uppercase tracking-widest mr-1">●</span> @product.AvailableQuantity left
                                </span>
                            }
                            else
                            {
                                <span class="text-xs font-bold text-red-400 uppercase tracking-widest">Sold out</span>
                            }

                            <button class="btn btn-primary btn-sm py-2 px-6" 
                                    @onclick="() => OpenOrderModal(product)" 
                                    disabled="@(product.AvailableQuantity <= 0)">
                                Order
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

@if (_selectedProduct != null)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-stone-950/40 backdrop-blur-sm" @onclick="CloseOrderModal"></div>
        <div class="relative glass-card w-full max-w-md p-8 shadow-2xl animate-in fade-in zoom-in duration-300">
            <button class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center rounded-2xl hover:bg-bakery-crust/5 transition-colors text-2xl" @onclick="CloseOrderModal">×</button>
            
            <div class="mb-8">
                <span class="text-xs font-black uppercase tracking-widest text-bakery-crust dark:text-amber-500 mb-2 block">Order Item</span>
                <h3 class="text-3xl font-serif font-black">@_selectedProduct.Name</h3>
            </div>
            
            <EditForm Model="_orderModel" OnValidSubmit="PlaceOrder" class="space-y-6">
                <div class="form-group">
                    <label class="form-label" for="customerName">Your Name</label>
                    <InputText id="customerName" class="form-control" @bind-Value="_orderModel.CustomerName" placeholder="Enter your name" required />
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="quantity">Quantity</label>
                    <InputNumber id="quantity" class="form-control" @bind-Value="_orderModel.Quantity" min="1" max="@_selectedProduct.AvailableQuantity" required />
                </div>
                
                <div class="p-4 rounded-2xl bg-bakery-dough/30 dark:bg-stone-800/50 border border-bakery-crust/5 flex justify-between items-center">
                    <span class="font-bold text-stone-500">Total Price</span>
                    <strong class="text-2xl font-serif font-black text-bakery-crust dark:text-amber-500">
                        $@((_orderModel.Quantity * _selectedProduct.Price).ToString("0.00"))
                    </strong>
                </div>

                <div class="flex gap-3">
                    <button type="button" class="btn btn-outline flex-1" @onclick="CloseOrderModal">Cancel</button>
                    <button type="submit" class="btn btn-accent flex-1" disabled="@_isOrdering">
                        @(_isOrdering ? "Placing..." : "Confirm")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_notificationMessage))
{
    <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-[200] animate-in slide-in-from-bottom-8 duration-500">
        <div class="px-6 py-3 rounded-2xl shadow-xl backdrop-blur-md flex items-center gap-3 @(_notificationIsError ? "bg-red-500 text-white" : "bg-bakery-crust text-bakery-dough")">
            <span class="text-lg">@(_notificationIsError ? "⚠" : "✨")</span>
            <span class="font-bold text-sm tracking-tight">@_notificationMessage</span>
        </div>
    </div>
}

@code {
    private List<ProductItem>? _products;
    private bool _isLoading = true;
    private ProductItem? _selectedProduct;
    private OrderModel _orderModel = new();
    private bool _isOrdering = false;
    private string _notificationMessage = "";
    private bool _notificationIsError = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        _isLoading = true;
        try
        {
            _products = await ApiClient.GetAvailableProductsAsync();
        }
        catch (Exception)
        {
            ShowNotification("Failed to load products.", true);
            _products = new();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetImageForProduct(string name)
    {
        if (name.Contains("Croissant", StringComparison.OrdinalIgnoreCase)) return "/images/butter_croissant.png";
        if (name.Contains("Sourdough", StringComparison.OrdinalIgnoreCase)) return "/images/sourdough_loaf.png";
        if (name.Contains("Eclair") || name.Contains("Éclair")) return "/images/chocolate_eclair.png";
        return "/images/placeholder_pastry.png"; // Fallback image
    }

    private void OpenOrderModal(ProductItem product)
    {
        _selectedProduct = product;
        _orderModel = new OrderModel { Quantity = 1 };
    }

    private void CloseOrderModal()
    {
        _selectedProduct = null;
    }

    private async Task PlaceOrder()
    {
        if (_selectedProduct == null || _isOrdering) return;
        
        _isOrdering = true;
        
        try
        {
            var request = new OrderRequest(_selectedProduct.Id, _orderModel.Quantity, _orderModel.CustomerName);
            var response = await ApiClient.PlaceOrderAsync(request);

            ShowNotification(response.Message, !response.Success);
            
            if (response.Success)
            {
                CloseOrderModal();
                await LoadProducts(); // Refresh stock
            }
        }
        catch (Exception ex)
        {
            ShowNotification($"Order failed: {ex.Message}", true);
        }
        finally
        {
            _isOrdering = false;
        }
    }
    
    private void ShowNotification(string message, bool isError)
    {
        _notificationMessage = message;
        _notificationIsError = isError;
        StateHasChanged();
        
        _ = Task.Run(async () =>
        {
            await Task.Delay(4000);
            _notificationMessage = "";
            await InvokeAsync(StateHasChanged);
        });
    }

    private class OrderModel
    {
        public string CustomerName { get; set; } = "";
        public int Quantity { get; set; } = 1;
    }
}
