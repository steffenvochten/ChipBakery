@page "/inventory"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient
@implements IDisposable

<PageTitle>Inventory · ChipBakery</PageTitle>

<div class="space-y-10 animate-fade-up">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <SectionHeader Eyebrow="storeroom"
                       Subtitle="What's on the counter today. Edit prices, restock by hand, or pull a product from the menu.">
            Inventory
        </SectionHeader>
        <PaperButton Variant="ButtonVariant.Chocolate"
                     Glyph="glyph-plus"
                     OnClick="OpenCreateModal">
            Add product
        </PaperButton>
    </div>

    <LedgerTable TItem="InventoryItem"
                 Items="@_inventory"
                 Loading="@_isLoading"
                 EmptyHeadline="No products in the catalogue">
        <Header>
            <th>Name</th>
            <th>Price</th>
            <th>Stock</th>
            <th class="text-right">Actions</th>
        </Header>
        <Row Context="item">
            <td>
                <div class="font-serif font-bold text-base text-ink">@item.Name</div>
            </td>
            <td>
                <span class="font-mono text-sm">€@item.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)</span>
            </td>
            <td>
                @if (item.Quantity == 0)
                {
                    <StatusBadge Status="BakeryStatus.OutOfStock" RotateKey="@item.Id" />
                }
                else if (item.Quantity <= 5)
                {
                    <Stamp Color="BakeryColor.Raspberry" Glyph="glyph-clock" RotateKey="@item.Id">
                        Low · @item.Quantity left
                    </Stamp>
                }
                else
                {
                    <Stamp Color="BakeryColor.Basil" Glyph="glyph-check" RotateKey="@item.Id">
                        @item.Quantity in stock
                    </Stamp>
                }
            </td>
            <td class="text-right">
                <div class="flex justify-end gap-1">
                    <button type="button"
                            class="w-8 h-8 flex items-center justify-center rounded-xl hover:bg-ink/10 transition-colors text-ink"
                            title="Edit"
                            @onclick="() => OpenEditModal(item)">
                        <Doodle Name="glyph-pencil" Class="w-4 h-4" ViewBox="0 0 24 24" />
                    </button>
                    <button type="button"
                            class="w-8 h-8 flex items-center justify-center rounded-xl hover:bg-raspberry/15 transition-colors text-raspberry"
                            title="Delete"
                            @onclick="() => AskDelete(item)">
                        <Doodle Name="glyph-trash" Class="w-4 h-4" ViewBox="0 0 24 24" />
                    </button>
                </div>
            </td>
        </Row>
    </LedgerTable>
</div>

<RecipeModal @bind-Open="_isModalOpen"
             Title="@(_isEditMode ? "Edit product" : "Add product")"
             Eyebrow="@(_isEditMode ? "update" : "new arrival")"
             Size="Md">
    <ChildContent>
        <EditForm Model="_model" OnValidSubmit="SaveItem">
            <div class="space-y-5">
                <FormField Label="Product name" For="name" Required="true">
                    <InputText id="name" class="form-control" @bind-Value="_model.Name" placeholder="e.g. Butter croissant" />
                </FormField>
                <div class="grid grid-cols-2 gap-4">
                    <FormField Label="Price (€)" For="price">
                        <InputNumber id="price" class="form-control font-mono" @bind-Value="_model.Price" min="0.01" step="0.01" />
                    </FormField>
                    <FormField Label="Stock" For="quantity">
                        <InputNumber id="quantity" class="form-control font-mono" @bind-Value="_model.Quantity" min="0" />
                    </FormField>
                </div>
                <button type="submit" class="hidden" id="hidden-submit">submit</button>
            </div>
        </EditForm>
    </ChildContent>
    <Footer>
        <PaperButton Variant="ButtonVariant.Ghost" OnClick="CloseModal" Disabled="@_isSaving">Cancel</PaperButton>
        <PaperButton Variant="ButtonVariant.Chocolate"
                     Loading="@_isSaving"
                     OnClick="SaveItem">
            @(_isEditMode ? "Save changes" : "Add product")
        </PaperButton>
    </Footer>
</RecipeModal>

<Confirm @bind-Open="_confirmDeleteOpen"
         Title="@($"Delete {_pendingDeleteName}?")"
         Eyebrow="heads up"
         ConfirmLabel="Yes, delete"
         OnConfirm="ConfirmDelete">
    This will remove the product from the catalogue. Existing orders are unaffected.
</Confirm>

<Toast @bind-Message="_toast" Variant="@_toastVariant" />

@code {
    private List<InventoryItem>? _inventory;
    private bool _isLoading = true;

    private bool _isModalOpen;
    private bool _isEditMode;
    private Guid? _editingId;
    private InventoryModel _model = new();
    private bool _isSaving;

    private bool _confirmDeleteOpen;
    private Guid _pendingDeleteId;
    private string _pendingDeleteName = "";

    private string? _toast;
    private Toast.ToastVariant _toastVariant = Toast.ToastVariant.Success;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadInventory();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(async () =>
        {
            await LoadInventory();
            StateHasChanged();
        }), null, 2000, 2000);
    }

    public void Dispose() => _timer?.Dispose();

    private async Task LoadInventory()
    {
        try
        {
            _inventory = await ApiClient.GetAllInventoryAsync();
        }
        catch (Exception ex)
        {
            ShowToast($"Failed to load inventory: {ex.Message}", Toast.ToastVariant.Error);
            _inventory = new();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenCreateModal()
    {
        _isEditMode = false;
        _editingId  = null;
        _model      = new InventoryModel { Price = 1.00m, Quantity = 10 };
        _isModalOpen = true;
    }

    private void OpenEditModal(InventoryItem item)
    {
        _isEditMode = true;
        _editingId  = item.Id;
        _model      = new InventoryModel { Name = item.Name, Price = item.Price, Quantity = item.Quantity };
        _isModalOpen = true;
    }

    private void CloseModal() => _isModalOpen = false;

    private async Task SaveItem()
    {
        if (_isSaving) return;
        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            ShowToast("Product needs a name.", Toast.ToastVariant.Error);
            return;
        }

        _isSaving = true;
        try
        {
            if (_isEditMode && _editingId.HasValue)
            {
                var req = new UpdateInventoryRequest(_model.Name, _model.Price, _model.Quantity);
                var result = await ApiClient.UpdateInventoryItemAsync(_editingId.Value, req);
                if (result != null)
                {
                    ShowToast("Product updated.", Toast.ToastVariant.Success);
                    CloseModal();
                    await LoadInventory();
                }
                else
                {
                    ShowToast("Failed to update product.", Toast.ToastVariant.Error);
                }
            }
            else
            {
                var req = new CreateInventoryRequest(_model.Name, _model.Price, _model.Quantity);
                var result = await ApiClient.CreateInventoryItemAsync(req);
                if (result != null)
                {
                    ShowToast("Product added.", Toast.ToastVariant.Success);
                    CloseModal();
                    await LoadInventory();
                }
                else
                {
                    ShowToast("Failed to add product.", Toast.ToastVariant.Error);
                }
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Save failed: {ex.Message}", Toast.ToastVariant.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void AskDelete(InventoryItem item)
    {
        _pendingDeleteId   = item.Id;
        _pendingDeleteName = item.Name;
        _confirmDeleteOpen = true;
    }

    private async Task ConfirmDelete()
    {
        _confirmDeleteOpen = false;
        try
        {
            var success = await ApiClient.DeleteInventoryItemAsync(_pendingDeleteId);
            if (success)
            {
                ShowToast("Product deleted.", Toast.ToastVariant.Success);
                await LoadInventory();
            }
            else
            {
                ShowToast("Failed to delete product.", Toast.ToastVariant.Error);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Delete failed: {ex.Message}", Toast.ToastVariant.Error);
        }
    }

    private void ShowToast(string msg, Toast.ToastVariant variant)
    {
        _toastVariant = variant;
        _toast = msg;
    }

    private class InventoryModel
    {
        public string  Name     { get; set; } = "";
        public decimal Price    { get; set; }
        public int     Quantity { get; set; }
    }
}
