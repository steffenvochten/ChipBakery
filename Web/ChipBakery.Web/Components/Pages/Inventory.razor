@page "/inventory"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient

<PageTitle>Inventory Management | Chip Bakery</PageTitle>

<div class="space-y-8">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-4xl font-serif font-black text-bakery-crust dark:text-amber-500">Inventory</h1>
            <p class="text-stone-500 font-medium">Manage your artisanal product catalog.</p>
        </div>
        <button class="btn btn-primary shadow-lg shadow-bakery-crust/20" @onclick="OpenCreateModal">
            <span class="text-lg mr-2">+</span> Add Product
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="space-y-4">
            @for(int i=0; i<5; i++) {
                <div class="glass-card h-20 animate-pulse"></div>
            }
        </div>
    }
    else if (_inventory == null || !_inventory.Any())
    {
        <div class="glass-card p-16 text-center">
            <div class="text-6xl mb-6">📦</div>
            <h3 class="text-2xl font-serif font-black mb-2">No inventory items</h3>
            <p class="text-stone-500">Add some products to your catalogue to get started.</p>
        </div>
    }
    else
    {
        <div class="glass-card overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-bakery-crust/5 border-b border-bakery-crust/10">
                            <th class="px-6 py-4 text-xs font-black uppercase tracking-widest text-bakery-crust/60">Product Name</th>
                            <th class="px-6 py-4 text-xs font-black uppercase tracking-widest text-bakery-crust/60">Price</th>
                            <th class="px-6 py-4 text-xs font-black uppercase tracking-widest text-bakery-crust/60">Stock Status</th>
                            <th class="px-6 py-4 text-xs font-black uppercase tracking-widest text-bakery-crust/60 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-bakery-crust/5">
                        @foreach (var item in _inventory)
                        {
                            <tr class="hover:bg-bakery-crust/5 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="font-bold text-stone-900 dark:text-stone-100">@item.Name</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm font-medium opacity-80">$@item.Price.ToString("0.00")</div>
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.Quantity <= 5)
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 text-[0.7rem] font-black uppercase tracking-widest">
                                            Low: @item.Quantity left
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 text-[0.7rem] font-black uppercase tracking-widest">
                                            @item.Quantity in stock
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex justify-end gap-2">
                                        <button class="w-8 h-8 flex items-center justify-center rounded-xl bg-amber-100 text-amber-700 hover:bg-amber-500 hover:text-white transition-all shadow-sm" title="Edit" @onclick="() => OpenEditModal(item)">
                                            ✎
                                        </button>
                                        <button class="w-8 h-8 flex items-center justify-center rounded-xl bg-red-100 text-red-700 hover:bg-red-500 hover:text-white transition-all shadow-sm" title="Delete" @onclick="() => DeleteItem(item.Id)">
                                            ×
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (_isModalOpen)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-stone-950/40 backdrop-blur-sm" @onclick="CloseModal"></div>
        <div class="relative glass-card w-full max-w-md p-8 shadow-2xl animate-in fade-in zoom-in duration-300">
            <button class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center rounded-2xl hover:bg-bakery-crust/5 transition-colors text-2xl" @onclick="CloseModal">×</button>
            
            <div class="mb-8">
                <span class="text-xs font-black uppercase tracking-widest text-bakery-crust dark:text-amber-500 mb-2 block">Management</span>
                <h3 class="text-3xl font-serif font-black">@(_isEditMode ? "Edit Product" : "Add Product")</h3>
            </div>
            
            <EditForm Model="_model" OnValidSubmit="SaveItem" class="space-y-6">
                <div class="form-group">
                    <label class="form-label" for="name">Product Name</label>
                    <InputText id="name" class="form-control" @bind-Value="_model.Name" placeholder="e.g. Butter Croissant" required />
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="form-group">
                        <label class="form-label" for="price">Price ($)</label>
                        <InputNumber id="price" class="form-control" @bind-Value="_model.Price" min="0.01" step="0.01" required />
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="quantity">Stock</label>
                        <InputNumber id="quantity" class="form-control" @bind-Value="_model.Quantity" min="0" required />
                    </div>
                </div>
                
                <div class="flex gap-3 pt-4">
                    <button type="button" class="btn btn-outline flex-1" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="btn btn-accent flex-1 shadow-lg shadow-amber-500/20" disabled="@_isSaving">
                        @(_isSaving ? "Saving..." : "Save Product")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_notificationMessage))
{
    <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-[200] animate-in slide-in-from-bottom-8 duration-500">
        <div class="px-6 py-3 rounded-2xl shadow-xl backdrop-blur-md flex items-center gap-3 @(_notificationIsError ? "bg-red-500 text-white" : "bg-bakery-crust text-bakery-dough")">
            <span class="text-lg">@(_notificationIsError ? "⚠" : "✨")</span>
            <span class="font-bold text-sm tracking-tight">@_notificationMessage</span>
        </div>
    </div>
}

@code {
    private List<InventoryItem>? _inventory;
    private bool _isLoading = true;
    
    // Modal state
    private bool _isModalOpen = false;
    private bool _isEditMode = false;
    private Guid? _editingId;
    private InventoryModel _model = new();
    private bool _isSaving = false;

    private string _notificationMessage = "";
    private bool _notificationIsError = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadInventory();
    }

    private async Task LoadInventory()
    {
        _isLoading = true;
        try
        {
            _inventory = await ApiClient.GetAllInventoryAsync();
        }
        catch (Exception ex)
        {
            ShowNotification($"Failed to load inventory: {ex.Message}", true);
            _inventory = new();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenCreateModal()
    {
        _isEditMode = false;
        _editingId = null;
        _model = new InventoryModel { Price = 1.00m, Quantity = 10 };
        _isModalOpen = true;
    }

    private void OpenEditModal(InventoryItem item)
    {
        _isEditMode = true;
        _editingId = item.Id;
        _model = new InventoryModel
        {
            Name = item.Name,
            Price = item.Price,
            Quantity = item.Quantity
        };
        _isModalOpen = true;
    }

    private void CloseModal()
    {
        _isModalOpen = false;
    }

    private async Task SaveItem()
    {
        if (_isSaving) return;
        _isSaving = true;

        try
        {
            if (_isEditMode && _editingId.HasValue)
            {
                var req = new UpdateInventoryRequest(_model.Name, _model.Price, _model.Quantity);
                var result = await ApiClient.UpdateInventoryItemAsync(_editingId.Value, req);
                if (result != null)
                {
                    ShowNotification("Product updated successfully.", false);
                    CloseModal();
                    await LoadInventory();
                }
                else
                {
                    ShowNotification("Failed to update product.", true);
                }
            }
            else
            {
                var req = new CreateInventoryRequest(_model.Name, _model.Price, _model.Quantity);
                var result = await ApiClient.CreateInventoryItemAsync(req);
                if (result != null)
                {
                    ShowNotification("Product added successfully.", false);
                    CloseModal();
                    await LoadInventory();
                }
                else
                {
                    ShowNotification("Failed to add product.", true);
                }
            }
        }
        catch (Exception ex)
        {
            ShowNotification($"Save failed: {ex.Message}", true);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteItem(Guid id)
    {
        try
        {
            var success = await ApiClient.DeleteInventoryItemAsync(id);
            if (success)
            {
                ShowNotification("Product deleted.", false);
                await LoadInventory();
            }
            else
            {
                ShowNotification("Failed to delete product.", true);
            }
        }
        catch (Exception ex)
        {
            ShowNotification($"Delete failed: {ex.Message}", true);
        }
    }

    private void ShowNotification(string message, bool isError)
    {
        _notificationMessage = message;
        _notificationIsError = isError;
        StateHasChanged();
        
        _ = Task.Run(async () =>
        {
            await Task.Delay(3000);
            _notificationMessage = "";
            await InvokeAsync(StateHasChanged);
        });
    }

    private class InventoryModel
    {
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public int Quantity { get; set; }
    }
}
