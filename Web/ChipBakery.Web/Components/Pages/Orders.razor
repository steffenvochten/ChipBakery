@page "/orders"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient
@inject TimezoneService TzService
@implements IDisposable

<PageTitle>Orders · ChipBakery</PageTitle>

<div class="space-y-10 animate-fade-up">
    <SectionHeader Eyebrow="the order book"
                   Subtitle="Every basket placed today, with what it cost and where it is in the bake.">
        Orders
    </SectionHeader>

    <LedgerTable TItem="OrderItem"
                 Items="@_orders"
                 Loading="@_isLoading">
        <Header>
            <th>Order</th>
            <th>Placed</th>
            <th>Customer</th>
            <th>Item</th>
            <th class="text-right">Total</th>
            <th>Status</th>
            <th class="text-right">Actions</th>
        </Header>
        <Row Context="order">
            <td>
                <code class="font-mono text-xs text-ink-muted">@order.Id.ToString().ToUpper()[..8]</code>
            </td>
            <td>
                <span class="font-mono text-sm text-ink-muted">@TzService.FormatLong(order.OrderDate)</span>
            </td>
            <td>
                <span class="font-serif font-bold">@order.CustomerName</span>
            </td>
            <td>
                <span class="font-bold">@GetProductName(order.ProductId)</span>
                <span class="text-ink-muted mx-1.5">×</span>
                <span class="font-mono font-bold text-chocolate">@order.Quantity</span>
            </td>
            <td class="text-right">
                <span class="font-mono font-bold">€@order.TotalPrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)</span>
            </td>
            <td>
                <StatusBadge Status="@MapStatus(order.Status)" RotateKey="@order.Id" />
            </td>
            <td class="text-right">
                @if (order.Status == OrderStatus.Placed)
                {
                    <button type="button"
                            class="w-8 h-8 inline-flex items-center justify-center rounded-xl hover:bg-raspberry/15 transition-colors text-raspberry"
                            title="Cancel order"
                            disabled="@_isCancelling"
                            @onclick="() => AskCancel(order)">
                        <Doodle Name="glyph-x" Class="w-4 h-4" ViewBox="0 0 24 24" />
                    </button>
                }
            </td>
        </Row>
        <Empty>
            <EmptyState Doodle="doodle-cookie" Headline="No orders yet">
                <ChildContent>
                    Your order book will fill up as soon as customers start placing orders.
                </ChildContent>
                <Action>
                    <PaperButton Href="/" Glyph="glyph-arrow-right" TrailingGlyph="true">
                        Open the storefront
                    </PaperButton>
                </Action>
            </EmptyState>
        </Empty>
    </LedgerTable>
</div>

<Confirm @bind-Open="_confirmCancelOpen"
         Title="Cancel this order?"
         Eyebrow="heads up"
         ConfirmLabel="Yes, cancel"
         CancelLabel="Keep it"
         Busy="@_isCancelling"
         OnConfirm="ConfirmCancel">
    Inventory will be restored. The customer won't be charged.
</Confirm>

<Toast @bind-Message="_toast" Variant="@_toastVariant" />

@code {
    private List<OrderItem>? _orders;
    private Dictionary<Guid, string> _productNames = new();
    private bool _isLoading = true;
    private bool _isCancelling;

    private bool _confirmCancelOpen;
    private Guid _pendingCancelId;

    private string? _toast;
    private Toast.ToastVariant _toastVariant = Toast.ToastVariant.Success;

    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(async () =>
        {
            await LoadOrders();
            StateHasChanged();
        }), null, 2000, 2000);
    }

    public void Dispose() => _timer?.Dispose();

    private async Task LoadOrders()
    {
        try
        {
            var ordersTask    = ApiClient.GetAllOrdersAsync();
            var inventoryTask = ApiClient.GetAllInventoryAsync();
            await Task.WhenAll(ordersTask, inventoryTask);

            _orders = ordersTask.Result;
            _productNames = inventoryTask.Result.ToDictionary(p => p.Id, p => p.Name);
        }
        catch (Exception ex)
        {
            ShowToast($"Failed to load orders: {ex.Message}", Toast.ToastVariant.Error);
            _orders = new();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetProductName(Guid id) =>
        _productNames.TryGetValue(id, out var name) ? name : "Unknown product";

    /// <summary>Maps OrderStatus to the BakeryStatus used by StatusBadge so the
    /// existing user-facing labels ("Baking", "Ready") are preserved.</summary>
    private static BakeryStatus MapStatus(OrderStatus s) => s switch
    {
        OrderStatus.Placed     => BakeryStatus.Placed,
        OrderStatus.Processing => BakeryStatus.Baking,
        OrderStatus.Completed  => BakeryStatus.Ready,
        OrderStatus.Cancelled  => BakeryStatus.Cancelled,
        _                      => BakeryStatus.Queued,
    };

    private void AskCancel(OrderItem order)
    {
        _pendingCancelId = order.Id;
        _confirmCancelOpen = true;
    }

    private async Task ConfirmCancel()
    {
        if (_isCancelling) return;
        _isCancelling = true;
        try
        {
            var success = await ApiClient.CancelOrderAsync(_pendingCancelId);
            if (success)
            {
                ShowToast("Order cancelled.", Toast.ToastVariant.Success);
                await LoadOrders();
            }
            else
            {
                ShowToast("Failed to cancel order.", Toast.ToastVariant.Error);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Cancel failed: {ex.Message}", Toast.ToastVariant.Error);
        }
        finally
        {
            _isCancelling = false;
            _confirmCancelOpen = false;
        }
    }

    private void ShowToast(string msg, Toast.ToastVariant variant)
    {
        _toastVariant = variant;
        _toast = msg;
    }
}
