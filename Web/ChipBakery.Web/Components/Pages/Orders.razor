@page "/orders"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient

<PageTitle>Order History | Chip Bakery</PageTitle>

<div class="space-y-8">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-4xl font-serif font-black text-bakery-crust dark:text-amber-500">Order History</h1>
            <p class="text-stone-500 font-medium">Track your artisanal bakes and deliveries.</p>
        </div>
        <button class="btn btn-outline" @onclick="LoadOrders" disabled="@_isLoading">
            <span class="mr-2">↻</span> Refresh
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="space-y-4">
            @for(int i=0; i<5; i++) {
                <div class="glass-card h-24 animate-pulse"></div>
            }
        </div>
    }
    else if (_orders == null || !_orders.Any())
    {
        <div class="glass-card p-16 text-center">
            <div class="text-6xl mb-6">🧾</div>
            <h3 class="text-2xl font-serif font-black mb-2">No orders yet</h3>
            <p class="text-stone-500 mb-8">Your order history will appear here once you place an order.</p>
            <a href="/" class="btn btn-primary px-8 shadow-lg shadow-bakery-crust/20">Go to Storefront</a>
        </div>
    }
    else
    {
        <div class="glass-card overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-bakery-crust/5 border-b border-bakery-crust/10">
                            <th class="px-6 py-4 text-xs font-black uppercase tracking-widest text-bakery-crust/60">Order ID</th>
                            <th class="px-6 py-4 text-xs font-black uppercase tracking-widest text-bakery-crust/60">Date</th>
                            <th class="px-6 py-4 text-xs font-black uppercase tracking-widest text-bakery-crust/60">Customer</th>
                            <th class="px-6 py-4 text-xs font-black uppercase tracking-widest text-bakery-crust/60">Product</th>
                            <th class="px-6 py-4 text-xs font-black uppercase tracking-widest text-bakery-crust/60">Total</th>
                            <th class="px-6 py-4 text-xs font-black uppercase tracking-widest text-bakery-crust/60">Status</th>
                            <th class="px-6 py-4 text-xs font-black uppercase tracking-widest text-bakery-crust/60 text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-bakery-crust/5">
                        @foreach (var order in _orders)
                        {
                            <tr class="hover:bg-bakery-crust/5 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="text-xs font-black text-stone-400 font-mono tracking-tighter">@order.Id.ToString().ToUpper()[..8]</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm font-medium opacity-80">@order.OrderDate.ToString("g")</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="font-bold text-stone-900 dark:text-stone-100">@order.CustomerName</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm">
                                        <span class="font-bold">@GetProductName(order.ProductId)</span>
                                        <span class="opacity-50 mx-1">×</span>
                                        <span class="font-black text-bakery-crust dark:text-amber-500">@order.Quantity</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="font-serif font-black text-lg">$@order.TotalPrice.ToString("0.00")</div>
                                </td>
                                <td class="px-6 py-4">
                                    @switch (order.Status)
                                    {
                                        case OrderStatus.Placed:
                                            <span class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 text-[0.7rem] font-black uppercase tracking-widest">Placed</span>
                                            break;
                                        case OrderStatus.Processing:
                                            <span class="inline-flex items-center px-3 py-1 rounded-full bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 text-[0.7rem] font-black uppercase tracking-widest">Baking</span>
                                            break;
                                        case OrderStatus.Completed:
                                            <span class="inline-flex items-center px-3 py-1 rounded-full bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 text-[0.7rem] font-black uppercase tracking-widest">Ready</span>
                                            break;
                                        case OrderStatus.Cancelled:
                                            <span class="inline-flex items-center px-3 py-1 rounded-full bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 text-[0.7rem] font-black uppercase tracking-widest">Cancelled</span>
                                            break;
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    @if (order.Status == OrderStatus.Placed)
                                    {
                                        <button class="w-8 h-8 flex items-center justify-center rounded-xl bg-red-100 text-red-700 hover:bg-red-500 hover:text-white transition-all shadow-sm" title="Cancel Order" @onclick="() => CancelOrder(order.Id)" disabled="@_isCancelling">
                                            ×
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(_notificationMessage))
{
    <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-[200] animate-in slide-in-from-bottom-8 duration-500">
        <div class="px-6 py-3 rounded-2xl shadow-xl backdrop-blur-md flex items-center gap-3 @(_notificationIsError ? "bg-red-500 text-white" : "bg-bakery-crust text-bakery-dough")">
            <span class="text-lg">@(_notificationIsError ? "⚠" : "✨")</span>
            <span class="font-bold text-sm tracking-tight">@_notificationMessage</span>
        </div>
    </div>
}

@code {
    private List<OrderItem>? _orders;
    private Dictionary<Guid, string> _productNames = new();
    private bool _isLoading = true;
    private bool _isCancelling = false;
    private string _notificationMessage = "";
    private bool _notificationIsError = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        _isLoading = true;
        try
        {
            _orders = await ApiClient.GetAllOrdersAsync();
            // Fetch products to map names if we haven't already
            if (!_productNames.Any())
            {
                var inventory = await ApiClient.GetAllInventoryAsync();
                foreach (var p in inventory)
                {
                    _productNames[p.Id] = p.Name;
                }
            }
        }
        catch (Exception ex)
        {
            ShowNotification($"Failed to load orders: {ex.Message}", true);
            _orders = new();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetProductName(Guid id)
    {
        return _productNames.TryGetValue(id, out var name) ? name : "Unknown Product";
    }

    private async Task CancelOrder(Guid id)
    {
        if (_isCancelling) return;
        _isCancelling = true;

        try
        {
            var success = await ApiClient.CancelOrderAsync(id);
            if (success)
            {
                ShowNotification("Order cancelled successfully.", false);
                await LoadOrders(); // Refresh table
            }
            else
            {
                ShowNotification("Failed to cancel order.", true);
            }
        }
        catch (Exception ex)
        {
            ShowNotification($"Error cancelling order: {ex.Message}", true);
        }
        finally
        {
            _isCancelling = false;
        }
    }

    private void ShowNotification(string message, bool isError)
    {
        _notificationMessage = message;
        _notificationIsError = isError;
        StateHasChanged();
        
        _ = Task.Run(async () =>
        {
            await Task.Delay(3000);
            _notificationMessage = "";
            await InvokeAsync(StateHasChanged);
        });
    }
}
