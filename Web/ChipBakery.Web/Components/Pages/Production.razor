@page "/production"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient
@inject TimezoneService TzService
@implements IDisposable

<PageTitle>Production · ChipBakery</PageTitle>

<div class="space-y-10 animate-fade-up">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <SectionHeader Eyebrow="the oven floor"
                       Subtitle="What's baking, what's queued, what's waiting on a sack of flour. Refreshes every 2 seconds.">
            Production
        </SectionHeader>
        <PaperButton Variant="@(_hideCompleted ? ButtonVariant.Chocolate : ButtonVariant.Outline)"
                     Glyph="glyph-check"
                     OnClick="() => _hideCompleted = !_hideCompleted">
            @(_hideCompleted ? "Show completed" : "Hide completed")
        </PaperButton>
    </div>

    @if (_errorMessage is not null)
    {
        <PaperCard Class="border-l-4" style="border-color: rgb(var(--raspberry));">
            <div class="flex items-center justify-between gap-4">
                <span class="font-bold text-raspberry">@_errorMessage</span>
                <PaperButton Variant="ButtonVariant.Outline" Size="BakerySize.Sm" OnClick="Retry">Retry</PaperButton>
            </div>
        </PaperCard>
    }

    @if (!_isLoading && _jobs.Count > 0)
    {
        var baking  = _jobs.Count(j => j.Status == BakingJobStatus.Baking);
        var waiting = _jobs.Count(j => j.Status == BakingJobStatus.AwaitingIngredients);
        var queued  = _jobs.Count(j => j.Status == BakingJobStatus.Scheduled);
        var done    = _jobs.Count(j => j.Status == BakingJobStatus.Completed);

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <Stat Label="Baking"   Value="@baking.ToString()"  Glyph="glyph-fire"    />
            <Stat Label="Awaiting" Value="@waiting.ToString()" Glyph="glyph-clock"   />
            <Stat Label="Queued"   Value="@queued.ToString()"  Glyph="utensil-timer" />
            <Stat Label="Done"     Value="@done.ToString()"    Glyph="glyph-check"   />
        </div>
    }

    <LedgerTable TItem="BakingJob"
                 Items="@DisplayJobs"
                 Loading="@_isLoading"
                 EmptyHeadline="No active baking jobs">
        <Header>
            <th>Product</th>
            <th>Status</th>
            <th class="text-right">Qty</th>
            <th>Started</th>
            <th>Finished</th>
        </Header>
        <Row Context="job">
            <td>
                <div class="font-serif font-bold text-ink">@ProductName(job.ProductId)</div>
                <code class="font-mono text-xs text-ink-muted">@job.Id.ToString()[..8]…</code>
            </td>
            <td>
                <StatusBadge StatusText="@job.Status" RotateKey="@job.Id" />
            </td>
            <td class="text-right">
                <span class="font-mono font-bold">@job.Quantity.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</span>
            </td>
            <td>
                <span class="font-mono text-sm text-ink-muted">@TzService.FormatTime(job.StartTime)</span>
            </td>
            <td>
                <span class="font-mono text-sm text-ink-muted">@TzService.FormatTime(job.EndTime)</span>
            </td>
        </Row>
    </LedgerTable>
</div>

@code {
    private List<BakingJob> _jobs = [];
    private Dictionary<Guid, string> _productNames = new();
    private bool _isLoading = true;
    private bool _hideCompleted;
    private string? _errorMessage;
    private System.Threading.Timer? _timer;

    private IEnumerable<BakingJob> DisplayJobs => _jobs
        .Where(j => !_hideCompleted || j.Status != BakingJobStatus.Completed)
        .OrderBy(j => j.Status switch
        {
            BakingJobStatus.Baking              => 0,
            BakingJobStatus.AwaitingIngredients => 1,
            BakingJobStatus.Scheduled           => 2,
            BakingJobStatus.Completed           => 3,
            _                                   => 4,
        })
        .ThenByDescending(j => j.StartTime ?? j.EndTime ?? DateTime.MinValue);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        }), null, 2000, 2000);
    }

    private async Task LoadData()
    {
        try
        {
            var jobsTask  = ApiClient.GetAllBakingJobsAsync();
            var itemsTask = ApiClient.GetAllInventoryAsync();
            await Task.WhenAll(jobsTask, itemsTask);

            _jobs         = jobsTask.Result;
            _productNames = itemsTask.Result.ToDictionary(i => i.Id, i => i.Name);
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load production data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string ProductName(Guid id) => _productNames.TryGetValue(id, out var n) ? n : "Unknown";

    private async Task Retry()
    {
        _isLoading = true;
        await LoadData();
        StateHasChanged();
    }

    public void Dispose() => _timer?.Dispose();
}
