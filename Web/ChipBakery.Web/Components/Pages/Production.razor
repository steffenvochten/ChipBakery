@page "/production"
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient

<PageTitle>Production Tracker - Chip Bakery</PageTitle>

<div class="space-y-8 animate-in fade-in duration-700">
    <div>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-bakery-crust dark:text-amber-400">
            Production Tracker
        </h1>
        <p class="text-lg text-bakery-crust/60 dark:text-stone-400 font-medium">
            Live monitoring of baking schedules and batches.
        </p>
    </div>

    <div class="glass-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-bakery-crust/5 dark:bg-stone-800/50 text-left">
                        <th class="p-6 text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500">Job ID</th>
                        <th class="p-6 text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500">Status</th>
                        <th class="p-6 text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500">Quantity</th>
                        <th class="p-6 text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500">Start Time</th>
                        <th class="p-6 text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500">End Time</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-bakery-crust/5 dark:divide-white/5">
                    @if (isLoading)
                    {
                        @foreach (var i in Enumerable.Range(0, 5))
                        {
                            <tr class="animate-pulse">
                                <td colspan="5" class="p-6">
                                    <div class="h-6 w-full bg-bakery-crust/5 dark:bg-stone-800/30 rounded-lg"></div>
                                </td>
                            </tr>
                        }
                    }
                    else if (!jobs.Any())
                    {
                        <tr>
                            <td colspan="5" class="p-16 text-center">
                                <div class="flex flex-col items-center gap-4 opacity-30">
                                    <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                    </svg>
                                    <p class="text-xl font-bold">No active baking jobs.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var job in jobs)
                        {
                            <tr class="hover:bg-bakery-crust/5 dark:hover:bg-white/5 transition-colors">
                                <td class="p-6 font-mono text-xs text-bakery-crust/60 dark:text-stone-400">@job.Id.ToString().Substring(0, 8)</td>
                                <td class="p-6">
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-black uppercase tracking-tighter @GetStatusClass(job.Status)">
                                        <span class="w-2 h-2 rounded-full mr-2 @GetStatusDotClass(job.Status)"></span>
                                        @job.Status
                                    </span>
                                </td>
                                <td class="p-6 font-bold text-bakery-crust dark:text-stone-100">@job.Quantity.ToString("N0") units</td>
                                <td class="p-6 text-sm text-stone-500">@(job.StartTime?.ToString("HH:mm:ss") ?? "-")</td>
                                <td class="p-6 text-sm text-stone-500">@(job.EndTime?.ToString("HH:mm:ss") ?? "-")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<BakingJob> jobs = new();
    private bool isLoading = true;
    private System.Threading.Timer? timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        // Poll for updates every 3 seconds to simulate "live" tracking
        timer = new System.Threading.Timer(async _ => await InvokeAsync(async () => {
            await LoadData();
            StateHasChanged();
        }), null, 3000, 3000);
    }

    private async Task LoadData()
    {
        try 
        {
            jobs = await ApiClient.GetAllBakingJobsAsync();
        }
        catch { /* handle error */ }
        finally 
        {
            isLoading = false;
        }
    }

    private string GetStatusClass(string status) => status switch
    {
        "Scheduled" => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400",
        "Baking" => "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 animate-pulse",
        "Completed" => "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400",
        _ => "bg-stone-100 text-stone-700 dark:bg-stone-800 dark:text-stone-300"
    };

    private string GetStatusDotClass(string status) => status switch
    {
        "Scheduled" => "bg-blue-500",
        "Baking" => "bg-amber-500",
        "Completed" => "bg-green-500",
        _ => "bg-stone-500"
    };

    public void Dispose() => timer?.Dispose();
}
