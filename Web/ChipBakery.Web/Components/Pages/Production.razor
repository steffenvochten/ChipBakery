@page "/production"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient
@inject TimezoneService TzService
@implements IDisposable

<PageTitle>Production Tracker - Chip Bakery</PageTitle>

<div class="space-y-8 animate-in fade-in duration-700">
    <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
            <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-bakery-crust dark:text-amber-400">
                Production Tracker
            </h1>
            <p class="text-lg text-bakery-crust/60 dark:text-stone-400 font-medium">
                Live monitoring of baking schedules and batches.
            </p>
        </div>

        <!-- Filter controls -->
        <div class="flex items-center gap-2">
            <button class="btn @(_hideCompleted ? "btn-primary" : "btn-outline") text-sm py-2 px-4"
                    @onclick="() => _hideCompleted = !_hideCompleted">
                @(_hideCompleted ? "Show Completed" : "Hide Completed")
            </button>
        </div>
    </div>

    @if (errorMessage != null)
    {
        <div class="rounded-3xl bg-red-100 dark:bg-red-900/30 border border-red-300/50 dark:border-red-700/40 text-red-700 dark:text-red-300 p-5 font-bold flex items-center justify-between gap-4">
            <span>@errorMessage</span>
            <button class="btn btn-outline py-2 text-xs" @onclick="Retry">Retry</button>
        </div>
    }

    <!-- Stats strip -->
    @if (!isLoading && jobs.Any())
    {
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            @{
                var baking   = jobs.Count(j => j.Status == BakingJobStatus.Baking);
                var waiting  = jobs.Count(j => j.Status == BakingJobStatus.AwaitingIngredients);
                var queued   = jobs.Count(j => j.Status == BakingJobStatus.Scheduled);
                var done     = jobs.Count(j => j.Status == BakingJobStatus.Completed);
            }
            <div class="glass-card p-4 text-center">
                <div class="text-2xl font-black text-amber-500">@baking</div>
                <div class="text-xs font-bold text-bakery-crust/50 dark:text-stone-500 uppercase tracking-widest mt-1">Baking</div>
            </div>
            <div class="glass-card p-4 text-center">
                <div class="text-2xl font-black text-red-500">@waiting</div>
                <div class="text-xs font-bold text-bakery-crust/50 dark:text-stone-500 uppercase tracking-widest mt-1">Awaiting Ingredients</div>
            </div>
            <div class="glass-card p-4 text-center">
                <div class="text-2xl font-black text-blue-500">@queued</div>
                <div class="text-xs font-bold text-bakery-crust/50 dark:text-stone-500 uppercase tracking-widest mt-1">Queued</div>
            </div>
            <div class="glass-card p-4 text-center">
                <div class="text-2xl font-black text-green-500">@done</div>
                <div class="text-xs font-bold text-bakery-crust/50 dark:text-stone-500 uppercase tracking-widest mt-1">Completed</div>
            </div>
        </div>
    }

    <div class="glass-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-bakery-crust/5 dark:bg-stone-800/50 text-left">
                        <th class="p-5 text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500">Product</th>
                        <th class="p-5 text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500">Status</th>
                        <th class="p-5 text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500">Qty</th>
                        <th class="p-5 text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500">Started</th>
                        <th class="p-5 text-xs font-black uppercase tracking-widest text-bakery-crust/40 dark:text-stone-500">Finished</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-bakery-crust/5 dark:divide-white/5">
                    @if (isLoading)
                    {
                        @foreach (var i in Enumerable.Range(0, 5))
                        {
                            <tr class="animate-pulse">
                                <td colspan="5" class="p-5">
                                    <div class="h-6 w-full bg-bakery-crust/5 dark:bg-stone-800/30 rounded-lg"></div>
                                </td>
                            </tr>
                        }
                    }
                    else if (!DisplayJobs.Any())
                    {
                        <tr>
                            <td colspan="5" class="p-16 text-center">
                                <div class="flex flex-col items-center gap-4 opacity-30">
                                    <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                    </svg>
                                    <p class="text-xl font-bold">No active baking jobs.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var job in DisplayJobs)
                        {
                            <tr class="hover:bg-bakery-crust/5 dark:hover:bg-white/5 transition-colors">
                                <td class="p-5">
                                    <div class="font-bold text-sm text-bakery-crust dark:text-stone-100">@ProductName(job.ProductId)</div>
                                    <div class="font-mono text-xs text-bakery-crust/30 dark:text-stone-600 mt-0.5">@job.Id.ToString()[..8]…</div>
                                </td>
                                <td class="p-5">
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-black uppercase tracking-tighter @GetStatusClass(job.Status)">
                                        <span class="w-2 h-2 rounded-full mr-2 @GetStatusDotClass(job.Status)"></span>
                                        @job.Status
                                    </span>
                                </td>
                                <td class="p-5 font-bold text-bakery-crust dark:text-stone-100">@job.Quantity.ToString("N0")</td>
                                <td class="p-5 text-sm font-mono text-stone-500">@TzService.FormatTime(job.StartTime)</td>
                                <td class="p-5 text-sm font-mono text-stone-500">@TzService.FormatTime(job.EndTime)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<BakingJob> jobs = [];
    private Dictionary<Guid, string> _productNames = new();
    private bool isLoading = true;
    private bool _hideCompleted = false;
    private System.Threading.Timer? timer;
    private string? errorMessage;

    private IEnumerable<BakingJob> DisplayJobs => jobs
        .Where(j => !_hideCompleted || j.Status != BakingJobStatus.Completed)
        .OrderBy(j => j.Status switch
        {
            BakingJobStatus.Baking               => 0,
            BakingJobStatus.AwaitingIngredients  => 1,
            BakingJobStatus.Scheduled            => 2,
            BakingJobStatus.Completed            => 3,
            _                                    => 4
        })
        .ThenByDescending(j => j.StartTime ?? j.EndTime ?? DateTime.MinValue);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        timer = new System.Threading.Timer(async _ => await InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        }), null, 2000, 2000);
    }

    private async Task LoadData()
    {
        try
        {
            var jobsTask  = ApiClient.GetAllBakingJobsAsync();
            var itemsTask = ApiClient.GetAllInventoryAsync();
            await Task.WhenAll(jobsTask, itemsTask);

            jobs = jobsTask.Result;
            _productNames = itemsTask.Result.ToDictionary(i => i.Id, i => i.Name);
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load production data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string ProductName(Guid id) =>
        _productNames.TryGetValue(id, out var n) ? n : "Unknown";

    private async Task Retry()
    {
        isLoading = true;
        await LoadData();
        StateHasChanged();
    }

    private static string GetStatusClass(string status) => status switch
    {
        BakingJobStatus.Scheduled            => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400",
        BakingJobStatus.Baking               => "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 animate-pulse",
        BakingJobStatus.Completed            => "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400",
        BakingJobStatus.AwaitingIngredients  => "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400",
        _                                    => "bg-stone-100 text-stone-700 dark:bg-stone-800 dark:text-stone-300"
    };

    private static string GetStatusDotClass(string status) => status switch
    {
        BakingJobStatus.Scheduled            => "bg-blue-500",
        BakingJobStatus.Baking               => "bg-amber-500 animate-pulse",
        BakingJobStatus.Completed            => "bg-green-500",
        BakingJobStatus.AwaitingIngredients  => "bg-red-500",
        _                                    => "bg-stone-500"
    };

    public void Dispose() => timer?.Dispose();
}
