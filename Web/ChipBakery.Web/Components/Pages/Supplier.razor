@page "/supplier"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient
@inject TimezoneService TzService
@implements IDisposable

<PageTitle>Supplier · ChipBakery</PageTitle>

<div class="space-y-12 animate-fade-up">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <SectionHeader Eyebrow="the back door"
                       Subtitle="Scheduled deliveries from the supplier and the running logbook of arrivals.">
            Supplier
        </SectionHeader>
        <PaperButton Variant="ButtonVariant.Chocolate"
                     Glyph="glyph-plus"
                     OnClick="OpenCreateModal">
            New supply
        </PaperButton>
    </div>

    <section class="space-y-5">
        <div class="flex items-baseline justify-between">
            <div>
                <div class="display-hand text-xl text-kraft leading-none mb-1">scheduled</div>
                <h2 class="font-serif font-bold text-2xl text-ink">Ingredient supplies</h2>
            </div>
            @if (_supplies is not null) {
                <span class="text-xs text-ink-muted">@_supplies.Count active</span>
            }
        </div>

        @if (_isLoadingSupplies)
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                @for (int i = 0; i < 3; i++) { <Skeleton Variant="Skeleton.SkeletonVariant.Card" /> }
            </div>
        }
        else if (_supplies is null || _supplies.Count == 0)
        {
            <PaperCard>
                <EmptyState Doodle="utensil-bowl" Headline="No scheduled supplies">
                    <ChildContent>Add a supply contract to start tracking deliveries.</ChildContent>
                    <Action><PaperButton Glyph="glyph-plus" OnClick="OpenCreateModal">New supply</PaperButton></Action>
                </EmptyState>
            </PaperCard>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var s in _supplies)
                {
                    <PaperCard RotateKey="@s.Id" Tape="TapeColor.Kraft" Hoverable="true">
                        <div class="flex items-start justify-between mb-3 gap-2">
                            <div class="min-w-0">
                                <div class="display-hand text-lg text-kraft leading-none mb-1">supply</div>
                                <h3 class="font-serif font-bold text-xl text-ink truncate">@s.IngredientName</h3>
                                <p class="text-sm text-ink-muted mt-1">from <span class="font-bold text-ink">@s.SupplierName</span></p>
                            </div>
                            <Stamp Color="BakeryColor.Kraft" RotateKey="@s.Id">@s.Quantity</Stamp>
                        </div>
                        <div class="flex items-baseline gap-2 mt-3">
                            <span class="font-mono font-bold text-2xl text-chocolate">€@s.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)</span>
                        </div>
                        <p class="text-xs font-mono text-ink-muted mt-2">arrives @TzService.FormatShort(s.ScheduledDate)</p>
                        <div class="mt-5 pt-3 border-t flex items-center gap-1" style="border-color: rgb(var(--ink) / 0.08);">
                            <PaperButton Variant="ButtonVariant.Outline"
                                         Size="BakerySize.Sm"
                                         Glyph="glyph-pencil"
                                         OnClick="() => OpenEditModal(s)">
                                Edit
                            </PaperButton>
                            <button type="button"
                                    class="ml-auto w-9 h-9 flex items-center justify-center rounded-xl hover:bg-raspberry/15 transition-colors text-raspberry"
                                    title="Delete"
                                    @onclick="() => AskDelete(s)">
                                <Doodle Name="glyph-trash" Class="w-4 h-4" ViewBox="0 0 24 24" />
                            </button>
                        </div>
                    </PaperCard>
                }
            </div>
        }
    </section>

    <section class="space-y-5">
        <div>
            <div class="display-hand text-xl text-kraft leading-none mb-1">logbook</div>
            <h2 class="font-serif font-bold text-2xl text-ink">Recent transports</h2>
        </div>

        <LedgerTable TItem="SupplierTransportDto"
                     Items="@_transports"
                     Loading="@_isLoadingTransports"
                     EmptyHeadline="No transports yet">
            <Header>
                <th>Ingredient</th>
                <th class="text-right">Quantity</th>
                <th>Arrived</th>
            </Header>
            <Row Context="t">
                <td><span class="font-serif font-bold">@t.IngredientName</span></td>
                <td class="text-right"><span class="font-mono">@t.Quantity.ToString("N2", System.Globalization.CultureInfo.InvariantCulture) <span class="text-ink-muted">@t.Unit</span></span></td>
                <td><span class="font-mono text-sm text-ink-muted">@TzService.FormatShort(t.Timestamp)</span></td>
            </Row>
        </LedgerTable>
    </section>
</div>

<RecipeModal @bind-Open="_isModalOpen"
             Title="@(_isEditMode ? "Edit supply" : "New supply")"
             Eyebrow="@(_isEditMode ? "update" : "schedule")"
             Size="Md">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_modalError))
        {
            <div class="mb-4 px-4 py-3 rounded-2xl text-sm font-bold"
                 style="background-color: rgb(var(--raspberry) / 0.12); color: rgb(var(--raspberry));"
                 role="alert">@_modalError</div>
        }
        <EditForm Model="_model" OnValidSubmit="SaveSupply">
            <div class="space-y-4">
                <FormField Label="Ingredient" Required="true">
                    <InputText class="form-control" @bind-Value="_model.IngredientName" />
                </FormField>
                <FormField Label="Supplier" Required="true">
                    <InputText class="form-control" @bind-Value="_model.SupplierName" />
                </FormField>
                <div class="grid grid-cols-2 gap-3">
                    <FormField Label="Quantity">
                        <InputNumber class="form-control font-mono" @bind-Value="_model.Quantity" min="1" />
                    </FormField>
                    <FormField Label="Price (€)">
                        <InputNumber class="form-control font-mono" @bind-Value="_model.Price" min="0.01" step="0.01" />
                    </FormField>
                </div>
                <FormField Label="Scheduled date">
                    <InputDate class="form-control" @bind-Value="_model.ScheduledDate" />
                </FormField>
            </div>
        </EditForm>
    </ChildContent>
    <Footer>
        <PaperButton Variant="ButtonVariant.Ghost" OnClick="() => _isModalOpen = false" Disabled="@_isSaving">Cancel</PaperButton>
        <PaperButton Variant="ButtonVariant.Chocolate" Loading="@_isSaving" OnClick="SaveSupply">
            @(_isEditMode ? "Save changes" : "Add supply")
        </PaperButton>
    </Footer>
</RecipeModal>

<Confirm @bind-Open="_confirmDeleteOpen"
         Title="@($"Delete supply for {_pendingDeleteName}?")"
         Eyebrow="heads up"
         ConfirmLabel="Yes, delete"
         OnConfirm="ConfirmDelete">
    The scheduled delivery will no longer arrive automatically.
</Confirm>

<Toast @bind-Message="_toast" Variant="@_toastVariant" />

@code {
    private List<IngredientSupplyDto>? _supplies;
    private List<SupplierTransportDto>? _transports;
    private bool _isLoadingSupplies = true;
    private bool _isLoadingTransports = true;

    private bool _isModalOpen;
    private bool _isEditMode;
    private Guid? _editingId;
    private SupplyModel _model = new();
    private bool _isSaving;
    private string? _modalError;

    private bool _confirmDeleteOpen;
    private Guid _pendingDeleteId;
    private string _pendingDeleteName = "";

    private string? _toast;
    private Toast.ToastVariant _toastVariant = Toast.ToastVariant.Success;

    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadSupplies(), LoadTransports());
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(async () =>
        {
            await Task.WhenAll(LoadSupplies(), LoadTransports());
            StateHasChanged();
        }), null, 2000, 2000);
    }

    public void Dispose() => _timer?.Dispose();

    private async Task LoadSupplies()
    {
        try
        {
            _supplies = await ApiClient.GetAllIngredientSuppliesAsync();
        }
        catch (Exception ex)
        {
            ShowToast($"Failed to load supplies: {ex.Message}", Toast.ToastVariant.Error);
            _supplies = new();
        }
        finally
        {
            _isLoadingSupplies = false;
        }
    }

    private async Task LoadTransports()
    {
        try
        {
            _transports = await ApiClient.GetAllSupplierTransportsAsync();
        }
        catch (Exception ex)
        {
            ShowToast($"Failed to load transports: {ex.Message}", Toast.ToastVariant.Error);
            _transports = new();
        }
        finally
        {
            _isLoadingTransports = false;
        }
    }

    private void OpenCreateModal()
    {
        _isEditMode = false;
        _editingId  = null;
        _model      = new SupplyModel { Quantity = 10, Price = 1.00m, ScheduledDate = DateTime.Today.AddDays(1) };
        _modalError = null;
        _isModalOpen = true;
    }

    private void OpenEditModal(IngredientSupplyDto s)
    {
        _isEditMode = true;
        _editingId  = s.Id;
        _model      = new SupplyModel
        {
            IngredientName = s.IngredientName,
            SupplierName   = s.SupplierName,
            Quantity       = s.Quantity,
            Price          = s.Price,
            ScheduledDate  = s.ScheduledDate,
        };
        _modalError  = null;
        _isModalOpen = true;
    }

    private async Task SaveSupply()
    {
        if (_isSaving) return;
        _isSaving = true;
        _modalError = null;
        try
        {
            if (_isEditMode && _editingId.HasValue)
            {
                var req = new UpdateIngredientSupplyRequest(_model.IngredientName, _model.SupplierName, _model.Quantity, _model.Price, _model.ScheduledDate);
                await ApiClient.UpdateIngredientSupplyAsync(_editingId.Value, req);
                ShowToast("Supply updated.", Toast.ToastVariant.Success);
            }
            else
            {
                var req = new CreateIngredientSupplyRequest(_model.IngredientName, _model.SupplierName, _model.Quantity, _model.Price, _model.ScheduledDate);
                await ApiClient.CreateIngredientSupplyAsync(req);
                ShowToast("Supply added.", Toast.ToastVariant.Success);
            }
            _isModalOpen = false;
            await LoadSupplies();
        }
        catch (Exception ex)
        {
            _modalError = $"Save failed: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void AskDelete(IngredientSupplyDto s)
    {
        _pendingDeleteId   = s.Id;
        _pendingDeleteName = s.IngredientName;
        _confirmDeleteOpen = true;
    }

    private async Task ConfirmDelete()
    {
        _confirmDeleteOpen = false;
        try
        {
            await ApiClient.DeleteIngredientSupplyAsync(_pendingDeleteId);
            await LoadSupplies();
            ShowToast("Supply deleted.", Toast.ToastVariant.Success);
        }
        catch (Exception ex)
        {
            ShowToast($"Delete failed: {ex.Message}", Toast.ToastVariant.Error);
        }
    }

    private void ShowToast(string msg, Toast.ToastVariant variant)
    {
        _toastVariant = variant;
        _toast = msg;
    }

    private class SupplyModel
    {
        public string   IngredientName { get; set; } = "";
        public string   SupplierName   { get; set; } = "";
        public int      Quantity       { get; set; }
        public decimal  Price          { get; set; }
        public DateTime ScheduledDate  { get; set; } = DateTime.Today;
    }
}
