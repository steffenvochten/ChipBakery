@page "/agents"
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@using Microsoft.AspNetCore.SignalR.Client
@inject AgentActivityClient ActivityClient
@implements IDisposable

<PageTitle>Agents - Chip Bakery</PageTitle>

<div class="space-y-8 animate-in fade-in duration-700">

    <!-- Header -->
    <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
            <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-bakery-crust dark:text-amber-400">
                Agent Command
            </h1>
            <p class="text-lg text-bakery-crust/60 dark:text-stone-400 font-medium">
                AI-driven agents running the bakery autonomously.
            </p>
        </div>

        <!-- Connection badge -->
        <div class="flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold
            @(ActivityClient.State == HubConnectionState.Connected
                ? "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400"
                : ActivityClient.State == HubConnectionState.Reconnecting
                    ? "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 animate-pulse"
                    : "bg-stone-100 text-stone-500 dark:bg-stone-800 dark:text-stone-400")">
            <span class="w-2 h-2 rounded-full
                @(ActivityClient.State == HubConnectionState.Connected ? "bg-green-500"
                  : ActivityClient.State == HubConnectionState.Reconnecting ? "bg-amber-500"
                  : "bg-stone-400")"></span>
            @(ActivityClient.State == HubConnectionState.Connected ? "Live"
              : ActivityClient.State == HubConnectionState.Reconnecting ? "Reconnecting…"
              : "Connecting…")
        </div>
    </div>

    <!-- Agent roster strip -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        @foreach (var agent in _roster)
        {
            <div class="glass-card p-4 flex flex-col items-center gap-2 text-center">
                <div class="text-2xl">@agent.Icon</div>
                <div class="font-black text-sm text-bakery-crust dark:text-stone-100 leading-tight">@agent.Name</div>
                <div class="text-xs font-bold text-bakery-crust/50 dark:text-stone-500">@agent.Role</div>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold
                    @(agent.Live ? "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400" : "bg-stone-100 text-stone-500 dark:bg-stone-800 dark:text-stone-500")">
                    <span class="w-1.5 h-1.5 rounded-full @(agent.Live ? "bg-green-500" : "bg-stone-400")"></span>
                    @(agent.Live ? "Active" : "Coming soon")
                </span>
            </div>
        }
    </div>

    <!-- Activity feed -->
    <div class="glass-card overflow-hidden">
        <div class="px-6 py-4 border-b border-bakery-crust/5 dark:border-white/5 flex items-center justify-between">
            <h2 class="font-black text-lg text-bakery-crust dark:text-stone-100">Live Activity Feed</h2>
            <span class="text-sm text-bakery-crust/40 dark:text-stone-500">
                @ActivityClient.Activities.Count event@(ActivityClient.Activities.Count == 1 ? "" : "s")
            </span>
        </div>

        <div class="divide-y divide-bakery-crust/5 dark:divide-white/5 max-h-[32rem] overflow-y-auto">
            @if (!ActivityClient.Activities.Any())
            {
                <div class="p-16 text-center">
                    <div class="flex flex-col items-center gap-4 opacity-30">
                        <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                        <p class="text-xl font-bold">Waiting for agent activity…</p>
                    </div>
                </div>
            }
            else
            {
                @foreach (var activity in ActivityClient.Activities)
                {
                    <div class="px-6 py-4 flex items-start gap-4 hover:bg-bakery-crust/3 dark:hover:bg-white/3 transition-colors animate-in fade-in duration-300">

                        <!-- Agent type colour dot -->
                        <div class="mt-1 w-2.5 h-2.5 rounded-full flex-shrink-0 @GetTypeDotClass(activity.AgentType)"></div>

                        <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-center gap-2 mb-1">
                                <span class="font-black text-sm text-bakery-crust dark:text-stone-100">
                                    @activity.AgentName
                                </span>
                                <span class="px-2 py-0.5 rounded-full text-xs font-bold @GetTypeBadgeClass(activity.AgentType)">
                                    @activity.AgentType
                                </span>
                                <span class="text-xs font-mono text-bakery-crust/30 dark:text-stone-600">
                                    @activity.Action
                                </span>
                            </div>
                            <p class="text-sm text-bakery-crust/70 dark:text-stone-300 italic">
                                "@activity.Narration"
                            </p>
                        </div>

                        <time class="text-xs font-mono text-bakery-crust/30 dark:text-stone-600 flex-shrink-0 mt-1">
                            @activity.Timestamp.ToLocalTime().ToString("HH:mm:ss")
                        </time>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private record AgentCard(string Icon, string Name, string Role, bool Live);

    private static readonly AgentCard[] _roster =
    [
        new("🛒", "Sarah",    "Regular client",   false),
        new("☕", "Marco",    "Café bulk-buyer",  false),
        new("🌸", "Lin",      "Curious newcomer", false),
        new("🌾", "Acme Flour Co",    "Supplier",  false),
        new("🍬", "Sweet Sugar Inc",  "Supplier",  false),
        new("🥛", "Dairy Direct",     "Supplier",  false),
        new("📦", "Warehouse Mgr",    "Manager",   false),
        new("🍞", "Baker",            "Baker",      false),
    ];

    protected override async Task OnInitializedAsync()
    {
        ActivityClient.OnChange += OnActivityReceived;
        await ActivityClient.StartAsync();
    }

    private void OnActivityReceived() => InvokeAsync(StateHasChanged);

    public void Dispose() => ActivityClient.OnChange -= OnActivityReceived;

    private static string GetTypeDotClass(string type) => type switch
    {
        "Client"    => "bg-pink-400",
        "Supplier"  => "bg-amber-400",
        "Warehouse" => "bg-blue-400",
        "Baker"     => "bg-green-400",
        _           => "bg-stone-400"
    };

    private static string GetTypeBadgeClass(string type) => type switch
    {
        "Client"    => "bg-pink-100 text-pink-700 dark:bg-pink-900/30 dark:text-pink-400",
        "Supplier"  => "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400",
        "Warehouse" => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400",
        "Baker"     => "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400",
        _           => "bg-stone-100 text-stone-600 dark:bg-stone-800 dark:text-stone-400"
    };
}
