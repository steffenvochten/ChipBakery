@page "/agents"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@using Microsoft.AspNetCore.SignalR.Client
@inject AgentActivityClient ActivityClient
@inject TimezoneService TzService
@implements IDisposable

<PageTitle>Agents · ChipBakery</PageTitle>

<div class="space-y-10 animate-fade-up">
    <div class="flex flex-wrap items-end justify-between gap-4">
        <SectionHeader Eyebrow="the night shift"
                       Subtitle="The kitchen runs itself. AI agents pick orders, restock the warehouse, and bake the queue.">
            Agents
        </SectionHeader>

        @* Connection status badge *@
        <Stamp Color="@StatusColor" Glyph="@StatusGlyph">@StatusLabel</Stamp>
    </div>

    @* ===========================================================
       Controls strip — chalkboard panel
       =========================================================== *@
    <div class="chalkboard-surface p-5 flex flex-wrap items-center gap-5">
        <div class="flex items-center gap-3">
            <Doodle Name="utensil-timer" Class="w-5 h-5 text-lemon" ViewBox="0 0 32 32" />
            <span class="display-hand text-lg text-paper leading-none">speed</span>
            <input type="range" min="0.5" max="5" step="0.5"
                   value="@_speed"
                   @onchange="async e => { _speed = Convert.ToDouble(e.Value); await ApplySpeed(); }"
                   class="w-32 accent-amber-400"
                   aria-label="Agent speed" />
            <span class="font-mono font-bold text-lemon w-10 tabular-nums">@_speed.ToString("0.#")×</span>
        </div>
        <div class="flex gap-2 ml-auto">
            <button type="button"
                    class="btn @(_isPaused ? "btn-kraft" : "btn-outline") text-sm"
                    style="@(_isPaused ? "" : "color: rgb(var(--paper)); border-color: rgb(var(--paper) / 0.5);")"
                    @onclick="TogglePause">
                @if (_isPaused)
                {
                    <Doodle Name="glyph-arrow-right" Class="w-4 h-4" ViewBox="0 0 24 24" />
                    <span>Resume</span>
                }
                else
                {
                    <Doodle Name="glyph-clock" Class="w-4 h-4" ViewBox="0 0 24 24" />
                    <span>Pause</span>
                }
            </button>
            <button type="button"
                    class="btn btn-outline text-sm"
                    style="color: rgb(var(--paper)); border-color: rgb(var(--paper) / 0.5);"
                    @onclick="ResetFeed">
                <Doodle Name="glyph-trash" Class="w-4 h-4" ViewBox="0 0 24 24" />
                Clear
            </button>
        </div>
    </div>

    @* ===========================================================
       Agent roster — staff lockers
       =========================================================== *@
    <section class="space-y-5">
        <div>
            <div class="display-hand text-lg text-kraft leading-none mb-1">on shift</div>
            <h2 class="font-serif font-bold text-2xl text-ink">The team</h2>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            @{ int i = 0; }
            @foreach (var agent in _roster)
            {
                var rotateKey = $"agent-{i}"; i++;
                <PaperCard RotateKey="@rotateKey" Tape="@TapeFor(agent.Type)" Class="text-center" Padding="p-4">
                    <div class="text-3xl mb-2" aria-hidden="true">@agent.Icon</div>
                    <div class="font-serif font-bold text-base text-ink leading-tight">@agent.Name</div>
                    <div class="text-xs text-ink-muted mt-1">@agent.Role</div>
                    <div class="mt-2 flex justify-center">
                        @if (agent.Live)
                        {
                            <Stamp Color="BakeryColor.Basil" Glyph="glyph-check" RotateKey="@rotateKey" Class="text-xs">On</Stamp>
                        }
                        else
                        {
                            <Stamp Color="BakeryColor.Kraft" RotateKey="@rotateKey" Class="text-xs">Soon</Stamp>
                        }
                    </div>
                </PaperCard>
            }
        </div>
    </section>

    @* ===========================================================
       Activity feed — bulletin board
       =========================================================== *@
    <section class="space-y-5">
        <div class="flex items-baseline justify-between">
            <div>
                <div class="display-hand text-lg text-kraft leading-none mb-1">the bulletin board</div>
                <h2 class="font-serif font-bold text-2xl text-ink">Live activity</h2>
            </div>
            <span class="text-sm text-ink-muted font-mono">
                @ActivityClient.Activities.Count event@(ActivityClient.Activities.Count == 1 ? "" : "s")
            </span>
        </div>

        <div class="paper-surface overflow-hidden">
            <div class="max-h-[36rem] overflow-y-auto">
                @if (ActivityClient.Activities.Count == 0)
                {
                    <EmptyState Doodle="utensil-timer" Headline="Nothing happening yet">
                        Agents will start chattering as soon as orders flow in.
                    </EmptyState>
                }
                else
                {
                    <ul class="divide-y" style="border-color: rgb(var(--ink) / 0.08);">
                        @foreach (var activity in ActivityClient.Activities)
                        {
                            <li class="px-5 py-4 flex items-start gap-4 hover:bg-ink/3 transition-colors">
                                <div class="mt-1 w-2.5 h-2.5 rounded-full flex-shrink-0"
                                     style="@TypeDotStyle(activity.AgentType)"
                                     aria-hidden="true"></div>

                                <div class="flex-1 min-w-0">
                                    <div class="flex flex-wrap items-center gap-2 mb-1">
                                        <span class="font-serif font-bold text-sm text-ink">@activity.AgentName</span>
                                        <Stamp Color="@TypeColor(activity.AgentType)" RotateKey="@activity.AgentType" Class="text-[0.65rem]">
                                            @activity.AgentType
                                        </Stamp>
                                        <code class="font-mono text-xs text-ink-muted">@activity.Action</code>
                                    </div>
                                    <p class="text-sm text-ink-muted italic font-serif">"@activity.Narration"</p>
                                </div>

                                <time class="text-xs font-mono text-ink-muted flex-shrink-0 mt-1">
                                    @TzService.FormatTime(activity.Timestamp)
                                </time>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </section>
</div>

@code {
    private record AgentCard(string Icon, string Name, string Role, string Type, bool Live);

    private static readonly AgentCard[] _roster =
    [
        new("🛒", "Sarah",            "Regular client",     "Client",    true),
        new("☕", "Marco",            "Café bulk-buyer",    "Client",    true),
        new("🌸", "Lin",              "Curious newcomer",   "Client",    true),
        new("🌾", "Acme Flour Co.",   "Flour supplier",     "Supplier",  true),
        new("🍬", "Sweet Sugar Inc.", "Sugar supplier",     "Supplier",  true),
        new("🥛", "Dairy Direct",     "Dairy supplier",     "Supplier",  true),
        new("📦", "Warehouse Mgr",    "Manager",            "Warehouse", true),
        new("🍞", "Baker",            "Baker",              "Baker",     true),
    ];

    private double _speed = 1.0;
    private bool _isPaused;

    private BakeryColor StatusColor => ActivityClient.State switch
    {
        HubConnectionState.Connected    => BakeryColor.Basil,
        HubConnectionState.Reconnecting => BakeryColor.Lemon,
        _                               => BakeryColor.Kraft,
    };

    private string StatusGlyph => ActivityClient.State switch
    {
        HubConnectionState.Connected    => "glyph-check",
        HubConnectionState.Reconnecting => "glyph-clock",
        _                               => "glyph-clock",
    };

    private string StatusLabel => ActivityClient.State switch
    {
        HubConnectionState.Connected    => "Live",
        HubConnectionState.Reconnecting => "Reconnecting",
        _                               => "Connecting",
    };

    protected override async Task OnInitializedAsync()
    {
        ActivityClient.OnChange += OnActivityReceived;
        await ActivityClient.StartAsync();
    }

    private async void OnActivityReceived() => await InvokeAsync(StateHasChanged);

    private async Task ApplySpeed() => await ActivityClient.SetSpeedAsync(_speed);

    private async Task TogglePause()
    {
        _isPaused = !_isPaused;
        await ActivityClient.SetPausedAsync(_isPaused);
    }

    private void ResetFeed() => ActivityClient.ClearActivities();

    public void Dispose() => ActivityClient.OnChange -= OnActivityReceived;

    private static BakeryColor TypeColor(string type) => type switch
    {
        "Client"    => BakeryColor.Raspberry,
        "Supplier"  => BakeryColor.Lemon,
        "Warehouse" => BakeryColor.Blueberry,
        "Baker"     => BakeryColor.Basil,
        _           => BakeryColor.Kraft,
    };

    private static TapeColor TapeFor(string type) => type switch
    {
        "Client"    => TapeColor.Raspberry,
        "Supplier"  => TapeColor.Lemon,
        "Warehouse" => TapeColor.Default,
        "Baker"     => TapeColor.Basil,
        _           => TapeColor.Kraft,
    };

    private static string TypeDotStyle(string type) => type switch
    {
        "Client"    => "background-color: rgb(var(--raspberry));",
        "Supplier"  => "background-color: rgb(var(--lemon));",
        "Warehouse" => "background-color: rgb(var(--blueberry));",
        "Baker"     => "background-color: rgb(var(--basil));",
        _           => "background-color: rgb(var(--kraft));",
    };
}
