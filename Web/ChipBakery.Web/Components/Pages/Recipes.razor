@page "/recipes"
@rendermode InteractiveServer
@using ChipBakery.Shared
@using ChipBakery.Web.Services
@inject BakeryApiClient ApiClient
@implements IDisposable

<PageTitle>Recipes · ChipBakery</PageTitle>

<div class="space-y-10 animate-fade-up">
    <SectionHeader Eyebrow="grandma's notebook"
                   Subtitle="Each product carries its own ingredient list. Production consumes these from the warehouse on every bake.">
        Recipes
    </SectionHeader>

    @if (_isLoading)
    {
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            @for (int i = 0; i < 4; i++)
            {
                <Skeleton Variant="Skeleton.SkeletonVariant.Card" />
            }
        </div>
    }
    else if (_products.Count == 0)
    {
        <PaperCard>
            <EmptyState Doodle="utensil-bowl" Headline="No products yet">
                Add inventory items first; recipes attach to existing products.
            </EmptyState>
        </PaperCard>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            @foreach (var product in _products)
            {
                var recipe = _recipes.FirstOrDefault(r => r.ProductId == product.Id);
                var hasRecipe = recipe is not null && recipe.Ingredients.Count > 0;

                <PaperCard RotateKey="@product.Id"
                           Tape="@(hasRecipe ? TapeColor.Lemon : TapeColor.Kraft)"
                           Hoverable="true">
                    <div class="flex items-start justify-between gap-3 mb-4">
                        <div class="min-w-0">
                            <div class="display-hand text-xl text-kraft leading-none mb-1">recipe for</div>
                            <h3 class="font-serif font-bold text-2xl text-ink truncate">@product.Name</h3>
                        </div>
                        @if (hasRecipe)
                        {
                            <Stamp Color="BakeryColor.Basil" Glyph="glyph-check" RotateKey="@product.Id">Tested</Stamp>
                        }
                        else
                        {
                            <Stamp Color="BakeryColor.Raspberry" Glyph="glyph-clock" RotateKey="@product.Id">Draft</Stamp>
                        }
                    </div>

                    @if (hasRecipe)
                    {
                        <ul class="space-y-1.5 font-mono text-sm">
                            @foreach (var ing in recipe!.Ingredients)
                            {
                                <li class="flex items-baseline gap-3">
                                    <span class="text-ink-muted">·</span>
                                    <span class="font-bold text-ink whitespace-nowrap">@ing.QuantityRequired.ToString("G", System.Globalization.CultureInfo.InvariantCulture)&nbsp;@ing.Unit</span>
                                    <span class="text-ink truncate">@ing.IngredientName</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-sm text-ink-muted italic">
                            No ingredients defined yet — baking will succeed but no warehouse stock is consumed.
                        </p>
                    }

                    <div class="flex items-center gap-2 mt-5 pt-4 border-t" style="border-color: rgb(var(--ink) / 0.08);">
                        <PaperButton Size="BakerySize.Sm"
                                     Variant="ButtonVariant.Outline"
                                     Glyph="glyph-pencil"
                                     OnClick="() => OpenModal(product, recipe)">
                            @(hasRecipe ? "Edit" : "Add ingredients")
                        </PaperButton>
                        @if (hasRecipe)
                        {
                            <PaperButton Size="BakerySize.Sm"
                                         Variant="ButtonVariant.Ghost"
                                         Glyph="glyph-trash"
                                         OnClick="() => AskDelete(product.Id, product.Name)">
                                Delete
                            </PaperButton>
                        }
                    </div>
                </PaperCard>
            }
        </div>
    }
</div>

<RecipeModal @bind-Open="_modalOpen"
             Title="@(_modalProduct?.Name ?? "Recipe")"
             Eyebrow="ingredients"
             Size="Lg">
    <ChildContent>
        @if (_modalProduct is not null)
        {
            <p class="text-sm text-ink-muted mb-4">Quantities consumed per single unit baked.</p>

            @if (!string.IsNullOrEmpty(_modalError))
            {
                <div class="mb-4 px-4 py-3 rounded-2xl text-sm font-bold"
                     style="background-color: rgb(var(--raspberry) / 0.12); color: rgb(var(--raspberry));"
                     role="alert">
                    @_modalError
                </div>
            }

            <div class="space-y-3 mb-4">
                @for (int i = 0; i < _editIngredients.Count; i++)
                {
                    var idx = i;
                    var ing = _editIngredients[idx];
                    <div class="flex flex-col sm:flex-row gap-2 sm:items-end">
                        <div class="flex-1">
                            @if (idx == 0) { <label class="form-label">Ingredient</label> }
                            <input class="form-control"
                                   placeholder="e.g. Bread flour"
                                   value="@ing.IngredientName"
                                   @oninput="e => ing.IngredientName = e.Value?.ToString() ?? string.Empty" />
                        </div>
                        <div class="w-full sm:w-28">
                            @if (idx == 0) { <label class="form-label">Qty</label> }
                            <input class="form-control font-mono"
                                   type="number" step="0.001" min="0.001"
                                   @bind:get="ing.QuantityRequired"
                                   @bind:set="v => ing.QuantityRequired = v"
                                   @bind:event="oninput"
                                   @bind:culture="@System.Globalization.CultureInfo.InvariantCulture" />
                        </div>
                        <div class="w-full sm:w-24">
                            @if (idx == 0) { <label class="form-label">Unit</label> }
                            <input class="form-control"
                                   placeholder="kg"
                                   value="@ing.Unit"
                                   @oninput="e => ing.Unit = e.Value?.ToString() ?? string.Empty" />
                        </div>
                        <button type="button"
                                class="w-9 h-9 flex-shrink-0 flex items-center justify-center rounded-xl hover:bg-raspberry/15 transition-colors text-raspberry mb-0.5"
                                aria-label="Remove ingredient"
                                @onclick="() => RemoveIngredient(idx)">
                            <Doodle Name="glyph-trash" Class="w-4 h-4" ViewBox="0 0 24 24" />
                        </button>
                    </div>
                }
            </div>

            <PaperButton Variant="ButtonVariant.Outline"
                         Size="BakerySize.Sm"
                         Glyph="glyph-plus"
                         OnClick="AddIngredientRow">
                Add ingredient
            </PaperButton>
        }
    </ChildContent>
    <Footer>
        <PaperButton Variant="ButtonVariant.Ghost" OnClick="CloseModal" Disabled="@_isSaving">Cancel</PaperButton>
        <PaperButton Variant="ButtonVariant.Chocolate" OnClick="SaveRecipe" Loading="@_isSaving">Save recipe</PaperButton>
    </Footer>
</RecipeModal>

<Confirm @bind-Open="_confirmDeleteOpen"
         Title="@($"Delete recipe for {_pendingDeleteName}?")"
         Eyebrow="heads up"
         ConfirmLabel="Yes, delete"
         CancelLabel="Keep it"
         OnConfirm="ConfirmDelete">
    Production will continue to bake this product without consuming any ingredients.
</Confirm>

<Toast @bind-Message="_toast" Variant="@_toastVariant" />

@code {
    private List<InventoryItem> _products = new();
    private List<RecipeDto> _recipes = new();
    private bool _isLoading = true;
    private System.Threading.Timer? _timer;

    private bool _modalOpen;
    private InventoryItem? _modalProduct;
    private List<EditIngredient> _editIngredients = new();
    private string? _modalError;
    private bool _isSaving;

    private bool _confirmDeleteOpen;
    private Guid _pendingDeleteId;
    private string _pendingDeleteName = "";

    private string? _toast;
    private Toast.ToastVariant _toastVariant = Toast.ToastVariant.Success;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        }), null, 5000, 5000);
    }

    public void Dispose() => _timer?.Dispose();

    private async Task LoadData()
    {
        try
        {
            var p = ApiClient.GetAllInventoryAsync();
            var r = ApiClient.GetAllRecipesAsync();
            await Task.WhenAll(p, r);
            _products = await p;
            _recipes  = await r;
        }
        catch (Exception ex)
        {
            ShowToast($"Failed to load: {ex.Message}", Toast.ToastVariant.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenModal(InventoryItem product, RecipeDto? existing)
    {
        _modalProduct    = product;
        _modalError      = null;
        _editIngredients = existing?.Ingredients
            .Select(i => new EditIngredient { IngredientName = i.IngredientName, QuantityRequired = i.QuantityRequired, Unit = i.Unit })
            .ToList() ?? new();
        if (_editIngredients.Count == 0)
            _editIngredients.Add(new());
        _modalOpen = true;
    }

    private void CloseModal()
    {
        _modalOpen = false;
        _modalProduct = null;
        _isSaving = false;
    }

    private void AddIngredientRow() => _editIngredients.Add(new());

    private void RemoveIngredient(int idx)
    {
        if (_editIngredients.Count > 1)
            _editIngredients.RemoveAt(idx);
    }

    private async Task SaveRecipe()
    {
        if (_isSaving || _modalProduct is null) return;

        var valid = _editIngredients.Where(i => !string.IsNullOrWhiteSpace(i.IngredientName) && i.QuantityRequired > 0 && !string.IsNullOrWhiteSpace(i.Unit)).ToList();
        if (valid.Count == 0)
        {
            _modalError = "Add at least one ingredient with a name, quantity, and unit.";
            return;
        }

        _isSaving   = true;
        _modalError = null;
        try
        {
            var req = new CreateRecipeRequest(
                _modalProduct.Id,
                _modalProduct.Name,
                valid.Select(i => new CreateRecipeIngredientRequest(i.IngredientName, i.QuantityRequired, i.Unit)).ToList());

            var result = await ApiClient.UpsertRecipeAsync(req);
            if (result == null)
            {
                _modalError = "Failed to save recipe.";
                return;
            }

            await LoadData();
            CloseModal();
            ShowToast($"Recipe saved for {req.ProductName}.", Toast.ToastVariant.Success);
        }
        catch (Exception ex)
        {
            _modalError = $"Save failed: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void AskDelete(Guid productId, string name)
    {
        _pendingDeleteId   = productId;
        _pendingDeleteName = name;
        _confirmDeleteOpen = true;
    }

    private async Task ConfirmDelete()
    {
        _confirmDeleteOpen = false;
        try
        {
            await ApiClient.DeleteRecipeAsync(_pendingDeleteId);
            await LoadData();
            ShowToast("Recipe deleted.", Toast.ToastVariant.Success);
        }
        catch (Exception ex)
        {
            ShowToast($"Delete failed: {ex.Message}", Toast.ToastVariant.Error);
        }
    }

    private void ShowToast(string msg, Toast.ToastVariant variant)
    {
        _toastVariant = variant;
        _toast = msg;
    }

    private class EditIngredient
    {
        public string  IngredientName   { get; set; } = string.Empty;
        public decimal QuantityRequired { get; set; }
        public string  Unit             { get; set; } = string.Empty;
    }
}
